---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/motifs.css';
import PwaShell from '../components/PwaShell.svelte';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  surfaceMode?: 'engineering' | 'welcome';
}

const {
  title,
  description = 'Wyreup — privacy-first browser-native tools. No uploads. No signup.',
  ogTitle = title,
  ogDescription = description,
  surfaceMode = 'engineering',
} = Astro.props;

const currentPath = Astro.url.pathname;
const bodyClass = surfaceMode === 'welcome' ? 'surface-welcome' : '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAF7F0" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111113" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Wyreup" />

    <!-- App-name + Windows tile metas (paired with PWA manifest below).
         msapplication-* drives Edge/Windows pinning; application-name
         is the legacy header browsers still respect for "show the app
         as X" surfaces. -->
    <meta name="application-name" content="Wyreup" />
    <meta name="msapplication-TileColor" content="#FFB000" />
    <meta name="msapplication-TileImage" content="/pwa-512.png" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- PWA manifest. The injectManifest strategy doesn't auto-inject this;
         every layout that ships HTML must reference it explicitly so the
         browser surfaces the install prompt and install criteria pass. -->
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Open Graph — PNG is the primary because LinkedIn / Twitter / X
         don't reliably render SVG og:image. Regenerate via
         `pnpm run build:og` after editing the SVG. -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content="https://wyreup.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wyreup" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://wyreup.com/og-image.png" />

    <title>{title}</title>

    <slot name="head" />

    <!-- Pre-paint layout reservation. Several components hydrate from
         localStorage (saved chains, recent tools, PWA install state) and
         render nothing during SSR. Without reservation, when those
         components mount and add content, everything below them jumps —
         the visible "flash" the user reported on /tools.

         This script runs before first paint, reads the same localStorage
         keys those components use, and sets CSS custom properties that
         reserve the correct vertical space. The Svelte components then
         fill that already-reserved space without triggering a shift.

         Numbers are rough averages of the rendered components — they're
         allowed to be slightly off; the goal is to eliminate the *jump*,
         not to be pixel-perfect. -->
    <script is:inline>
      (function () {
        try {
          var html = document.documentElement;

          // Recent tools strip in ToolFilter. ~24px pill + 16px bottom
          // margin. Only reserves if the user has at least one entry.
          var recentRaw = localStorage.getItem('wyreup:recent-tools');
          if (recentRaw) {
            var recents = JSON.parse(recentRaw);
            if (Array.isArray(recents) && recents.length > 0) {
              html.style.setProperty('--reserve-recent', '56px');
            }
          }

          // Saved chains section above the tool grid. Header (~36px) +
          // gap + 1+ rows of ~140px cards. Cards wrap at minmax(260px),
          // assume 4 per row at desktop. Always at least one row when
          // chains exist.
          var chainsRaw = localStorage.getItem('wyreup:my-kit:chains');
          if (chainsRaw) {
            var chains = JSON.parse(chainsRaw);
            if (Array.isArray(chains) && chains.length > 0) {
              var rows = Math.max(1, Math.ceil(chains.length / 4));
              var px = 36 + 12 + rows * 140 + 32; // header + gap + rows + bottom margin
              html.style.setProperty('--reserve-saved-chains', px + 'px');
            }
          }

          // PWA install banner. Two surfaces: standalone-mode welcome,
          // iOS install hint. Welcome dismisses persist; iOS hint
          // dismisses persist separately. Reserve only when at least
          // one will actually render.
          var ua = navigator.userAgent;
          var isIos = /iPad|iPhone|iPod/.test(ua) && !('MSStream' in window);
          var isStandalone =
            window.matchMedia('(display-mode: standalone)').matches ||
            navigator.standalone === true;
          var welcomeDismissed = localStorage.getItem('wyreup:pwa-onboard-dismissed');
          var iosDismissed = localStorage.getItem('wyreup:pwa-ios-install-dismissed');
          var willShowBanner =
            (isStandalone && !welcomeDismissed) ||
            (!isStandalone && isIos && !iosDismissed);
          if (willShowBanner) {
            html.style.setProperty('--reserve-pwa-banner', '48px');
          }
        } catch (e) {
          // localStorage unavailable (private mode, embedded, etc.) —
          // accept the small first-load shift in that edge case rather
          // than failing the whole page.
        }
      })();
    </script>
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <PwaShell client:load />

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark" aria-current={currentPath === '/' ? 'page' : undefined}>wyreup</a>

        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/tools" class="nav-link" aria-current={currentPath.startsWith('/tools') ? 'page' : undefined}>Tools</a>
          <a href="/chains" class="nav-link" aria-current={currentPath === '/chains' || currentPath === '/my-kit' || currentPath.startsWith('/chain') ? 'page' : undefined}>Chains</a>

          <!-- "Other surfaces" dropdown — Wyreup is also a CLI + an
               agent skill (MCP). Reframed from "For developers" so
               agent users (Claude, Cursor, ChatGPT desktop) see they
               can use the same toolbelt without touching code. -->
          <div class="dev-menu" id="dev-menu">
            <button
              class="nav-link dev-menu__trigger"
              id="dev-menu-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="dev-menu-dropdown"
            >Use anywhere <span class="dev-menu__caret" aria-hidden="true">&#9662;</span></button>
            <div
              class="dev-menu__dropdown"
              id="dev-menu-dropdown"
              role="menu"
              aria-label="Other surfaces — CLI, agent, GitHub"
              hidden
            >
              <a href="/skill" class="dev-menu__item" role="menuitem">From your AI agent (MCP)</a>
              <a href="/cli" class="dev-menu__item" role="menuitem">From the terminal (CLI)</a>
              <a href="/settings" class="dev-menu__item" role="menuitem">Settings &amp; storage</a>
              <a
                href="https://github.com/tamler/wyreup"
                class="dev-menu__item"
                role="menuitem"
                target="_blank"
                rel="noopener noreferrer"
              >GitHub</a>
              <a href="/about" class="dev-menu__item" role="menuitem">Docs</a>
            </div>
          </div>

          <!-- Mobile-only links row (shown < 640px, dropdown hidden) -->
          <div class="dev-mobile-row" aria-label="Other surfaces">
            <a href="/skill" class="nav-link nav-link--dev-mobile">Agent</a>
            <a href="/cli" class="nav-link nav-link--dev-mobile">CLI</a>
            <a href="/settings" class="nav-link nav-link--dev-mobile">Settings</a>
            <a href="https://github.com/tamler/wyreup" class="nav-link nav-link--dev-mobile nav-link--github" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </nav>

        <!-- Header search — compact, rightmost (Cmd+K to focus) -->
        <div class="header-search-wrap" id="header-search-wrap">
          <span class="header-search-icon" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </span>
          <input
            id="header-search"
            class="header-search-input"
            type="search"
            placeholder="Search"
            aria-label="Search tools (Cmd+K)"
            autocomplete="off"
          />
          <div id="header-search-dropdown" class="header-search-dropdown" role="listbox" aria-label="Tool suggestions" hidden></div>
        </div>

        <!-- Mobile search toggle (magnifier icon, shown < 640px) -->
        <button class="header-search-toggle" id="header-search-toggle" aria-label="Search tools" aria-expanded="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </div>
    </header>

    <main class="site-main" id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-copy">&copy; {new Date().getFullYear()} Wyreup</span>
        <div class="footer-rule" aria-hidden="true">
          <span class="footer-rule__line"></span>
          <span class="footer-rule__pad"></span>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="https://github.com/tamler/wyreup" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
          <a href="/about" class="footer-link">About</a>
          <a href="/settings" class="footer-link">Settings</a>
          <a href="/sitemap.xml" class="footer-link">Sitemap</a>
          <a href="mailto:hello@wyreup.com?subject=Tool%20suggestion" class="footer-link">Suggest a tool</a>
        </nav>
      </div>
    </footer>

    <!-- Site-wide file-drop safety net.
         The browser's default behavior on a file drop is to navigate to
         the file URL (opening it in the current tab). If a user misses a
         visible drop zone, their file opens instead of being handled —
         a confusing failure mode. This listener catches drops anywhere
         on every page, preventDefaults them, and broadcasts a
         `wyreup:filedrop` CustomEvent that page-level components
         (HeroDrop, ToolFilter, runners) can subscribe to for routing.
         Specific zones that already call preventDefault keep working
         exactly as before; the safety net only fires when the drop
         wasn't handled. A `body.is-file-dragover` class is toggled
         while a file is being dragged anywhere over the window so the
         page can show a global affordance (see ring style below). -->
    <script is:inline>
      (function () {
        var depth = 0;

        function isFileDrag(e) {
          if (!e.dataTransfer) return false;
          var types = e.dataTransfer.types;
          if (!types) return false;
          for (var i = 0; i < types.length; i++) {
            if (types[i] === 'Files') return true;
          }
          return false;
        }

        document.addEventListener('dragenter', function (e) {
          if (!isFileDrag(e)) return;
          depth++;
          if (depth === 1 && document.body) {
            document.body.classList.add('is-file-dragover');
          }
        });

        document.addEventListener('dragleave', function (e) {
          if (!isFileDrag(e)) return;
          depth = Math.max(0, depth - 1);
          if (depth === 0 && document.body) {
            document.body.classList.remove('is-file-dragover');
          }
        });

        document.addEventListener(
          'dragover',
          function (e) {
            if (!isFileDrag(e)) return;
            // Required: without preventDefault on dragover, the drop event
            // never fires on the rest of the page.
            e.preventDefault();
          },
          false,
        );

        document.addEventListener('drop', function (e) {
          if (!isFileDrag(e)) return;
          depth = 0;
          if (document.body) document.body.classList.remove('is-file-dragover');
          // A specific zone already handled this drop — let it process and
          // leave the file alone. (Inner handlers call preventDefault before
          // the event reaches us via bubbling.)
          if (e.defaultPrevented) return;
          e.preventDefault();
          var files = e.dataTransfer ? e.dataTransfer.files : null;
          if (!files || files.length === 0) return;
          document.dispatchEvent(
            new CustomEvent('wyreup:filedrop', { detail: { files: files } }),
          );
        });
      })();
    </script>

    <!-- Service worker registration. registerSW.js is generated by
         @vite-pwa/astro at build time and lives at the site root. With
         registerType: 'autoUpdate' it auto-updates the SW on each page
         load; users see new tool versions on the next navigation. -->
    <script is:inline type="module" src="/registerSW.js"></script>
  </body>
</html>

<style>
  /* File-drag affordance — site-wide ring when a file is dragged over
     any page. Paired with the inline script above which toggles
     body.is-file-dragover. Pointer-events:none so it never intercepts
     clicks or drops; the ring is purely a visual hint that the whole
     window will accept the drop (no need to aim at a specific box). */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    border: 3px solid var(--accent);
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-sharp);
    z-index: 9999;
  }

  body.is-file-dragover::before {
    opacity: 1;
  }

  body.is-file-dragover::after {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: var(--accent-dim);
    opacity: 0.35;
    transition: opacity var(--duration-fast) var(--ease-sharp);
    z-index: 9998;
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    height: 48px;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-4);
    height: 100%;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    text-decoration: none;
    justify-self: start;
  }

  .wordmark:hover {
    color: var(--accent-text);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-self: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link[aria-current="page"] {
    color: var(--text-primary);
    border-bottom: 2px solid var(--accent-hover);
    padding-bottom: 1px;
  }

  /* Main */
  .site-main {
    flex: 1;
    min-width: 0;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-4) 0;
    margin-top: var(--space-12);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-subtle);
  }

  .footer-rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex: 1;
  }

  .footer-rule__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .footer-rule__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .footer-link:hover {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 48px;
      gap: var(--space-2);
      grid-template-columns: unset;
    }

    .site-header {
      height: 48px;
    }

    .site-nav {
      gap: var(--space-3);
      justify-self: unset;
      flex-wrap: nowrap;
    }

    .nav-link {
      font-size: var(--text-xs);
      padding: var(--space-1) 0;
      min-height: 36px;
      display: flex;
      align-items: center;
    }

    .nav-link--github {
      display: none;
    }
  }

  @media (max-width: 375px) {
    .site-nav {
      gap: var(--space-2);
    }
  }

  /* ── Developer dropdown ── */
  .dev-menu {
    position: relative;
  }

  .dev-menu__trigger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color var(--duration-instant) var(--ease-sharp);
    white-space: nowrap;
  }

  .dev-menu__trigger:hover {
    color: var(--text-primary);
  }

  .dev-menu__trigger:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .dev-menu__caret {
    font-size: 10px;
    line-height: 1;
    color: var(--text-subtle);
  }

  .dev-menu__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    z-index: 50;
    min-width: 160px;
    padding: var(--space-1) 0;
    transform: translateY(-4px);
    opacity: 0;
    transition:
      opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .dev-menu__dropdown:not([hidden]) {
    transform: translateY(0);
    opacity: 1;
  }

  .dev-menu__dropdown[hidden] {
    display: none;
  }

  .dev-menu__item {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--duration-instant) var(--ease-sharp),
      background var(--duration-instant) var(--ease-sharp);
  }

  .dev-menu__item:hover {
    color: var(--text-primary);
    background: var(--bg-raised);
  }

  .dev-menu__item:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: -2px;
  }

  /* Mobile dev row — only visible < 640px */
  .dev-mobile-row {
    display: none;
  }

  @media (max-width: 639px) {
    .dev-menu {
      display: none;
    }

    .dev-mobile-row {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .nav-link--dev-mobile {
      font-size: var(--text-xs);
      padding: var(--space-1) 0;
      min-height: 36px;
      display: flex;
      align-items: center;
    }
  }

  @media (min-width: 640px) {
    .dev-menu {
      display: block;
    }
  }

  /* ── Header search ── */
  .header-search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    width: 160px;
    flex-shrink: 0;
    justify-self: end;
  }

  .header-search-icon {
    position: absolute;
    left: var(--space-2);
    display: flex;
    align-items: center;
    color: var(--text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }

  .header-search-input {
    height: 28px;
    padding: 0 var(--space-3) 0 calc(var(--space-2) + 13px + var(--space-2));
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    width: 100%;
    transition: border-color var(--duration-instant) var(--ease-sharp);
  }

  .header-search-input::placeholder {
    color: var(--text-subtle);
  }

  .header-search-input:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: 1px;
    border-color: var(--border);
  }

  .header-search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    z-index: 100;
    max-height: 440px;
    width: 420px;
    max-width: 90vw;
    overflow: hidden;
    padding: var(--space-1);
    display: flex;
    flex-direction: column;
  }

  .header-search-dropdown[hidden] {
    display: none;
  }

  /* Items below are injected via innerHTML at runtime, so they don't get
     Astro's scoped [data-astro-cid-*] attribute. We mark them :global so
     the styles actually apply. */

  :global(.header-suggest-results) {
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  :global(.header-suggest-item) {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    text-decoration: none;
    cursor: pointer;
    transition: background var(--duration-instant) var(--ease-sharp);
  }

  :global(.header-suggest-item:hover),
  :global(.header-suggest-item[aria-selected="true"]) {
    background: var(--bg-raised);
  }

  :global(.header-suggest-item__icon) {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  :global(.header-suggest-item:hover .header-suggest-item__icon),
  :global(.header-suggest-item[aria-selected="true"] .header-suggest-item__icon) {
    color: var(--accent-text);
  }

  :global(.header-suggest-item__body) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  :global(.header-suggest-item__name) {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.header-suggest-item__desc) {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.3;
  }

  :global(.header-suggest-item__cat) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  :global(.header-suggest-empty) {
    padding: var(--space-4) var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-align: center;
  }

  :global(.header-suggest-sep) {
    height: 1px;
    background: var(--border-subtle);
    margin: var(--space-1) 0;
    flex-shrink: 0;
  }

  :global(.header-suggest-item--footer) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: background var(--duration-instant) var(--ease-sharp);
    flex-shrink: 0;
  }

  :global(.header-suggest-item--footer:hover),
  :global(.header-suggest-item--footer[aria-selected="true"]) {
    background: var(--accent-dim);
  }

  :global(.header-suggest-item--footer::before) {
    content: '+';
    font-weight: 700;
    font-size: var(--text-md);
    line-height: 1;
  }

  /* Mobile toggle — shown only < 640px */
  .header-search-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: var(--space-1);
    align-items: center;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .header-search-toggle:hover {
    color: var(--text-primary);
  }

  @media (max-width: 639px) {
    .header-search-wrap {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border);
      width: auto;
      flex: none;
      z-index: 50;
      padding: var(--space-2) var(--space-4);
      height: 48px;
      justify-self: unset;
    }

    .header-search-wrap.mobile-open {
      display: flex;
    }

    .header-search-input {
      height: 32px;
    }

    .header-search-toggle {
      display: flex;
    }
  }
</style>

<script>
  // ── Header search: Fuse.js fuzzy search + CMD+K + navigation ──
  import { createToolSearch, searchTools } from '../lib/tool-search';
  import type { SearchableTool } from '../lib/tool-search';
  import { detectCapabilities, checkToolCapabilities } from '@wyreup/core';

  // Tool suggestions go to hello@wyreup.com — friendlier than a
  // GitHub Issues signup wall for non-technical users.
  const SUGGEST_EMAIL = 'hello@wyreup.com';

  const input = document.getElementById('header-search') as HTMLInputElement | null;
  const dropdown = document.getElementById('header-search-dropdown') as HTMLElement | null;
  const wrap = document.getElementById('header-search-wrap') as HTMLElement | null;
  const toggle = document.getElementById('header-search-toggle') as HTMLButtonElement | null;

  if (input && dropdown && wrap) {
    let fuse: ReturnType<typeof createToolSearch> | null = null;
    let selectedIdx = -1;
    const dd = dropdown;

    // 16px category icons — mirror ToolFilter.svelte's chipIcons
    const CATEGORY_ICONS: Record<string, string> = {
      optimize: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>',
      convert: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3l4 4-4 4"/><path d="M3 7h18"/><path d="M7 21l-4-4 4-4"/><path d="M21 17H3"/></svg>',
      pdf: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>',
      inspect: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
      create: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>',
      privacy: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
      extract: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>',
      generate: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>',
      text: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>',
      dev: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
      image: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>',
      export: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>',
      edit: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',
      finance: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="8"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="12" x2="14.5" y2="14.5"/></svg>',
      audio: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
      media: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>',
      archive: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="21 8 21 21 3 21 3 8"/><rect x="1" y="3" width="22" height="5"/><line x1="10" y1="12" x2="14" y2="12"/></svg>',
    };
    const DEFAULT_ICON = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>';

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    async function loadIndex() {
      try {
        const [res, caps] = await Promise.all([
          fetch('/tools-index.json'),
          detectCapabilities(),
        ]);
        if (res.ok) {
          const tools: SearchableTool[] = await res.json();
          // Hide tools the device can't run unless the user has flipped
          // the override on /tools (same key as the ToolFilter store).
          let showAll = false;
          try {
            showAll = localStorage.getItem('wyreup:show-unrunnable-tools') === '1';
          } catch {
            /* ignore */
          }
          const visible = showAll
            ? tools
            : tools.filter((t) => checkToolCapabilities(t, caps).runnable);
          fuse = createToolSearch(visible);
        }
      } catch {
        // silently ignore — search still works via form submit to /tools?q=
      }
    }

    loadIndex();

    function suggestUrl(query: string): string {
      const q = query.trim();
      const subject = q ? `Tool suggestion: ${q}` : 'Tool suggestion';
      const body = q
        ? `I searched for "${q}" but couldn't find a tool that fits. Could you add one?`
        : '';
      const params = new URLSearchParams();
      params.set('subject', subject);
      if (body) params.set('body', body);
      return `mailto:${SUGGEST_EMAIL}?${params.toString()}`;
    }

    function renderDropdown(
      results: Array<{ id: string; name: string; category: string; description: string }>,
      query: string,
    ) {
      const rows = results
        .slice(0, 10)
        .map((t, i) => {
          const icon = CATEGORY_ICONS[t.category] ?? DEFAULT_ICON;
          return `<a class="header-suggest-item" href="/tools/${encodeURIComponent(t.id)}" role="option" aria-selected="${i === selectedIdx}">`
            + `<span class="header-suggest-item__icon">${icon}</span>`
            + `<span class="header-suggest-item__body">`
            + `<span class="header-suggest-item__name">${escapeHtml(t.name)}</span>`
            + `<span class="header-suggest-item__desc">${escapeHtml(t.description ?? '')}</span>`
            + `</span>`
            + `<span class="header-suggest-item__cat">${escapeHtml(t.category)}</span>`
            + `</a>`;
        })
        .join('');

      const resultsBlock = results.length > 0
        ? `<div class="header-suggest-results">${rows}</div><div class="header-suggest-sep" aria-hidden="true"></div>`
        : '';

      const suggestRow = `<a class="header-suggest-item header-suggest-item--footer" href="${suggestUrl(query)}" role="option" aria-selected="false">Can't find it? Email a suggestion</a>`;

      dd.innerHTML = resultsBlock + suggestRow;
      dd.hidden = false;
    }

    input.addEventListener('input', () => {
      selectedIdx = -1;
      const q = input.value.trim();
      if (!q) {
        dd.hidden = true;
        return;
      }
      if (!fuse) {
        // Index not yet loaded — show suggest link only
        renderDropdown([], q);
        return;
      }
      const results = searchTools(fuse, q, 10).map((r) => r.tool);
      renderDropdown(results, q);
    });

    // CMD+K / Ctrl+K focus
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (window.innerWidth < 640) {
          wrap.classList.add('mobile-open');
          if (toggle) toggle.setAttribute('aria-expanded', 'true');
        }
        input.focus();
        input.select();
      }
      if (e.key === 'Escape') {
        dd.hidden = true;
        wrap.classList.remove('mobile-open');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Mobile toggle
    if (toggle) {
      toggle.addEventListener('click', () => {
        const open = wrap.classList.toggle('mobile-open');
        toggle.setAttribute('aria-expanded', String(open));
        if (open) {
          input.focus();
        }
      });
    }

    // Keyboard navigation in dropdown (skip the footer suggest link from arrow nav)
    input.addEventListener('keydown', (e) => {
      const items = dd.querySelectorAll<HTMLAnchorElement>('.header-suggest-item:not(.header-suggest-item--footer)');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIdx = Math.min(selectedIdx + 1, items.length - 1);
        items.forEach((el, i) => el.setAttribute('aria-selected', String(i === selectedIdx)));
        items[selectedIdx]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIdx = Math.max(selectedIdx - 1, -1);
        items.forEach((el, i) => el.setAttribute('aria-selected', String(i === selectedIdx)));
      } else if (e.key === 'Enter') {
        if (selectedIdx >= 0 && items[selectedIdx]) {
          e.preventDefault();
          items[selectedIdx].click();
        } else {
          // Navigate to /tools?q=<query>
          const q = encodeURIComponent(input.value.trim());
          if (q) {
            window.location.href = `/tools?q=${q}`;
          }
        }
      }
    });

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) {
        dd.hidden = true;
      }
    });
  }

  // ── Developer dropdown ──
  const devMenu = document.getElementById('dev-menu') as HTMLElement | null;
  const devTrigger = document.getElementById('dev-menu-trigger') as HTMLButtonElement | null;
  const devDropdown = document.getElementById('dev-menu-dropdown') as HTMLElement | null;

  if (devMenu && devTrigger && devDropdown) {
    const dTrigger = devTrigger as HTMLButtonElement;
    const dDropdown = devDropdown as HTMLElement;
    let devOpen = false;

    function openDevMenu() {
      devOpen = true;
      dDropdown.hidden = false;
      dTrigger.setAttribute('aria-expanded', 'true');
    }

    function closeDevMenu() {
      devOpen = false;
      dDropdown.hidden = true;
      dTrigger.setAttribute('aria-expanded', 'false');
    }

    // Hover opens the menu, but hover never closes it — closing is
    // always user intent (click outside, Escape, or click trigger again).
    // The original code closed on `mouseleave`, which fires when the cursor
    // crosses the 8px gap between trigger and dropdown. That dead zone was
    // making the dropdown unreachable.
    devMenu.addEventListener('mouseenter', openDevMenu);

    // Open on focus (keyboard)
    dTrigger.addEventListener('focus', openDevMenu);
    dTrigger.addEventListener('click', (e) => {
      e.stopPropagation(); // don't let the outside-click handler immediately close
      if (devOpen) {
        closeDevMenu();
      } else {
        openDevMenu();
        // Focus first item
        const first = dDropdown.querySelector<HTMLElement>('.dev-menu__item');
        first?.focus();
      }
    });

    // Trap focus within dropdown when open
    dDropdown.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeDevMenu();
        dTrigger.focus();
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!devMenu.contains(e.target as Node)) {
        closeDevMenu();
      }
    });

    // Close when focus leaves the menu
    devMenu.addEventListener('focusout', (e) => {
      if (!devMenu.contains(e.relatedTarget as Node)) {
        closeDevMenu();
      }
    });
  }
</script>
