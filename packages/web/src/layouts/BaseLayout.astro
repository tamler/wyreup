---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/motifs.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  surfaceMode?: 'engineering' | 'welcome';
}

const {
  title,
  description = 'Wyreup — privacy-first browser-native tools. No uploads. No signup.',
  ogTitle = title,
  ogDescription = description,
  surfaceMode = 'engineering',
} = Astro.props;

const currentPath = Astro.url.pathname;
const bodyClass = surfaceMode === 'welcome' ? 'surface-welcome' : '';
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFB000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Wyreup" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content="https://wyreup.com/og-image.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wyreup" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://wyreup.com/og-image.svg" />

    <title>{title}</title>

    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark" aria-current={currentPath === '/' ? 'page' : undefined}>wyreup</a>

        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/tools" class="nav-link" aria-current={currentPath.startsWith('/tools') ? 'page' : undefined}>Tools</a>
          <a href="/chains" class="nav-link" aria-current={currentPath === '/chains' || currentPath === '/my-kit' || currentPath.startsWith('/chain') ? 'page' : undefined}>Chains</a>

          <!-- "For developers" dropdown -->
          <div class="dev-menu" id="dev-menu">
            <button
              class="nav-link dev-menu__trigger"
              id="dev-menu-trigger"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="dev-menu-dropdown"
            >For developers <span class="dev-menu__caret" aria-hidden="true">&#9662;</span></button>
            <div
              class="dev-menu__dropdown"
              id="dev-menu-dropdown"
              role="menu"
              aria-label="Developer links"
              hidden
            >
              <a href="/cli" class="dev-menu__item" role="menuitem">CLI</a>
              <a href="/skill" class="dev-menu__item" role="menuitem">Agents (MCP + skill)</a>
              <a
                href="https://github.com/tamler/wyreup"
                class="dev-menu__item"
                role="menuitem"
                target="_blank"
                rel="noopener noreferrer"
              >GitHub</a>
              <a href="/about" class="dev-menu__item" role="menuitem">Docs</a>
            </div>
          </div>

          <!-- Mobile-only dev links row (shown < 640px, dropdown hidden) -->
          <div class="dev-mobile-row" aria-label="Developer links">
            <a href="/cli" class="nav-link nav-link--dev-mobile">CLI</a>
            <a href="/skill" class="nav-link nav-link--dev-mobile">Agents</a>
            <a href="https://github.com/tamler/wyreup" class="nav-link nav-link--dev-mobile nav-link--github" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </nav>

        <!-- Header search — compact, rightmost (Cmd+K to focus) -->
        <div class="header-search-wrap" id="header-search-wrap">
          <span class="header-search-icon" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </span>
          <input
            id="header-search"
            class="header-search-input"
            type="search"
            placeholder="Search"
            aria-label="Search tools (Cmd+K)"
            autocomplete="off"
          />
          <div id="header-search-dropdown" class="header-search-dropdown" role="listbox" aria-label="Tool suggestions" hidden></div>
        </div>

        <!-- Mobile search toggle (magnifier icon, shown < 640px) -->
        <button class="header-search-toggle" id="header-search-toggle" aria-label="Search tools" aria-expanded="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </div>
    </header>

    <main class="site-main" id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-copy">&copy; {new Date().getFullYear()} Wyreup</span>
        <div class="footer-rule" aria-hidden="true">
          <span class="footer-rule__line"></span>
          <span class="footer-rule__pad"></span>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="https://github.com/tamler/wyreup" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
          <a href="/about" class="footer-link">About</a>
          <a href="/settings" class="footer-link">Settings</a>
          <a href="/sitemap.xml" class="footer-link">Sitemap</a>
          <a href="https://github.com/tamler/wyreup/issues/new?template=tool-suggestion.yml" target="_blank" rel="noopener noreferrer" class="footer-link">Suggest a tool</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    height: 48px;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: var(--space-4);
    height: 100%;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    text-decoration: none;
    justify-self: start;
  }

  .wordmark:hover {
    color: var(--accent);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-self: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link[aria-current="page"] {
    color: var(--text-primary);
    border-bottom: 2px solid var(--accent);
    padding-bottom: 1px;
  }

  /* Main */
  .site-main {
    flex: 1;
    min-width: 0;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-4) 0;
    margin-top: var(--space-12);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-subtle);
  }

  .footer-rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex: 1;
  }

  .footer-rule__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .footer-rule__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .footer-link:hover {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 48px;
      gap: var(--space-2);
      grid-template-columns: unset;
    }

    .site-header {
      height: 48px;
    }

    .site-nav {
      gap: var(--space-3);
      justify-self: unset;
      flex-wrap: nowrap;
    }

    .nav-link {
      font-size: var(--text-xs);
      padding: var(--space-1) 0;
      min-height: 36px;
      display: flex;
      align-items: center;
    }

    .nav-link--github {
      display: none;
    }
  }

  @media (max-width: 375px) {
    .site-nav {
      gap: var(--space-2);
    }
  }

  /* ── Developer dropdown ── */
  .dev-menu {
    position: relative;
  }

  .dev-menu__trigger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color var(--duration-instant) var(--ease-sharp);
    white-space: nowrap;
  }

  .dev-menu__trigger:hover {
    color: var(--text-primary);
  }

  .dev-menu__trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .dev-menu__caret {
    font-size: 10px;
    line-height: 1;
    color: var(--text-subtle);
  }

  .dev-menu__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    z-index: 50;
    min-width: 160px;
    padding: var(--space-1) 0;
    transform: translateY(-4px);
    opacity: 0;
    transition:
      opacity var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .dev-menu__dropdown:not([hidden]) {
    transform: translateY(0);
    opacity: 1;
  }

  .dev-menu__dropdown[hidden] {
    display: none;
  }

  .dev-menu__item {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition:
      color var(--duration-instant) var(--ease-sharp),
      background var(--duration-instant) var(--ease-sharp);
  }

  .dev-menu__item:hover {
    color: var(--text-primary);
    background: var(--bg-raised);
  }

  .dev-menu__item:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  /* Mobile dev row — only visible < 640px */
  .dev-mobile-row {
    display: none;
  }

  @media (max-width: 639px) {
    .dev-menu {
      display: none;
    }

    .dev-mobile-row {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .nav-link--dev-mobile {
      font-size: var(--text-xs);
      padding: var(--space-1) 0;
      min-height: 36px;
      display: flex;
      align-items: center;
    }
  }

  @media (min-width: 640px) {
    .dev-menu {
      display: block;
    }
  }

  /* ── Header search ── */
  .header-search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    width: 160px;
    flex-shrink: 0;
    justify-self: end;
  }

  .header-search-icon {
    position: absolute;
    left: var(--space-2);
    display: flex;
    align-items: center;
    color: var(--text-muted);
    pointer-events: none;
    flex-shrink: 0;
  }

  .header-search-input {
    height: 28px;
    padding: 0 var(--space-3) 0 calc(var(--space-2) + 13px + var(--space-2));
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    width: 100%;
    transition: border-color var(--duration-instant) var(--ease-sharp);
  }

  .header-search-input::placeholder {
    color: var(--text-subtle);
  }

  .header-search-input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--border);
  }

  .header-search-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    z-index: 100;
    max-height: 280px;
    overflow-y: auto;
    padding: var(--space-1) 0;
  }

  .header-search-dropdown[hidden] {
    display: none;
  }

  .header-suggest-item {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color var(--duration-instant) var(--ease-sharp), background var(--duration-instant) var(--ease-sharp);
    cursor: pointer;
  }

  .header-suggest-item:hover,
  .header-suggest-item[aria-selected="true"] {
    color: var(--text-primary);
    background: var(--bg-raised);
  }

  .header-suggest-item__cat {
    color: var(--text-subtle);
    margin-left: var(--space-2);
    font-size: var(--text-xs);
  }

  .header-suggest-sep {
    height: 1px;
    background: var(--border-subtle);
    margin: var(--space-1) 0;
  }

  .header-suggest-item--footer {
    color: var(--text-subtle);
    font-style: italic;
  }

  .header-suggest-item--footer:hover,
  .header-suggest-item--footer[aria-selected="true"] {
    color: var(--text-muted);
    background: var(--bg-raised);
  }

  /* Mobile toggle — shown only < 640px */
  .header-search-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: var(--space-1);
    align-items: center;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .header-search-toggle:hover {
    color: var(--text-primary);
  }

  @media (max-width: 639px) {
    .header-search-wrap {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      background: var(--bg-elevated);
      border-bottom: 1px solid var(--border);
      width: auto;
      flex: none;
      z-index: 50;
      padding: var(--space-2) var(--space-4);
      height: 48px;
      justify-self: unset;
    }

    .header-search-wrap.mobile-open {
      display: flex;
    }

    .header-search-input {
      height: 32px;
    }

    .header-search-toggle {
      display: flex;
    }
  }
</style>

<script>
  // ── Header search: Fuse.js fuzzy search + CMD+K + navigation ──
  import { createToolSearch, searchTools } from '../lib/tool-search';
  import type { SearchableTool } from '../lib/tool-search';

  const SUGGEST_URL_BASE =
    'https://github.com/tamler/wyreup/issues/new?template=tool-suggestion.yml&title=Tool+suggestion%3A+';

  const input = document.getElementById('header-search') as HTMLInputElement | null;
  const dropdown = document.getElementById('header-search-dropdown') as HTMLElement | null;
  const wrap = document.getElementById('header-search-wrap') as HTMLElement | null;
  const toggle = document.getElementById('header-search-toggle') as HTMLButtonElement | null;

  if (input && dropdown && wrap) {
    let fuse: ReturnType<typeof createToolSearch> | null = null;
    let selectedIdx = -1;
    const dd = dropdown;

    async function loadIndex() {
      try {
        const res = await fetch('/tools-index.json');
        if (res.ok) {
          const tools: SearchableTool[] = await res.json();
          fuse = createToolSearch(tools);
        }
      } catch {
        // silently ignore — search still works via form submit to /tools?q=
      }
    }

    loadIndex();

    function suggestUrl(query: string): string {
      const q = query.trim();
      return q ? SUGGEST_URL_BASE + encodeURIComponent(q) : SUGGEST_URL_BASE;
    }

    function renderDropdown(
      results: Array<{ id: string; name: string; category: string }>,
      query: string,
    ) {
      const resultRows = results
        .slice(0, 10)
        .map(
          (t, i) =>
            `<a class="header-suggest-item" href="/tools/${t.id}" role="option" aria-selected="${i === selectedIdx}">${t.name}<span class="header-suggest-item__cat">${t.category}</span></a>`,
        )
        .join('');

      const suggestRow = `<a class="header-suggest-item header-suggest-item--footer" href="${suggestUrl(query)}" target="_blank" rel="noopener noreferrer" role="option" aria-selected="false">Can't find it? Suggest a tool</a>`;

      dd.innerHTML = (results.length > 0 ? resultRows + '<div class="header-suggest-sep" aria-hidden="true"></div>' : '') + suggestRow;
      dd.hidden = false;
    }

    input.addEventListener('input', () => {
      selectedIdx = -1;
      const q = input.value.trim();
      if (!q) {
        dd.hidden = true;
        return;
      }
      if (!fuse) {
        // Index not yet loaded — show suggest link only
        renderDropdown([], q);
        return;
      }
      const results = searchTools(fuse, q, 10).map((r) => r.tool);
      renderDropdown(results, q);
    });

    // CMD+K / Ctrl+K focus
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (window.innerWidth < 640) {
          wrap.classList.add('mobile-open');
          if (toggle) toggle.setAttribute('aria-expanded', 'true');
        }
        input.focus();
        input.select();
      }
      if (e.key === 'Escape') {
        dd.hidden = true;
        wrap.classList.remove('mobile-open');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Mobile toggle
    if (toggle) {
      toggle.addEventListener('click', () => {
        const open = wrap.classList.toggle('mobile-open');
        toggle.setAttribute('aria-expanded', String(open));
        if (open) {
          input.focus();
        }
      });
    }

    // Keyboard navigation in dropdown (skip the footer suggest link from arrow nav)
    input.addEventListener('keydown', (e) => {
      const items = dd.querySelectorAll<HTMLAnchorElement>('.header-suggest-item:not(.header-suggest-item--footer)');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIdx = Math.min(selectedIdx + 1, items.length - 1);
        items.forEach((el, i) => el.setAttribute('aria-selected', String(i === selectedIdx)));
        items[selectedIdx]?.scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIdx = Math.max(selectedIdx - 1, -1);
        items.forEach((el, i) => el.setAttribute('aria-selected', String(i === selectedIdx)));
      } else if (e.key === 'Enter') {
        if (selectedIdx >= 0 && items[selectedIdx]) {
          e.preventDefault();
          items[selectedIdx].click();
        } else {
          // Navigate to /tools?q=<query>
          const q = encodeURIComponent(input.value.trim());
          if (q) {
            window.location.href = `/tools?q=${q}`;
          }
        }
      }
    });

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) {
        dd.hidden = true;
      }
    });
  }

  // ── Developer dropdown ──
  const devMenu = document.getElementById('dev-menu') as HTMLElement | null;
  const devTrigger = document.getElementById('dev-menu-trigger') as HTMLButtonElement | null;
  const devDropdown = document.getElementById('dev-menu-dropdown') as HTMLElement | null;

  if (devMenu && devTrigger && devDropdown) {
    const dTrigger = devTrigger as HTMLButtonElement;
    const dDropdown = devDropdown as HTMLElement;
    let devOpen = false;

    function openDevMenu() {
      devOpen = true;
      dDropdown.hidden = false;
      dTrigger.setAttribute('aria-expanded', 'true');
    }

    function closeDevMenu() {
      devOpen = false;
      dDropdown.hidden = true;
      dTrigger.setAttribute('aria-expanded', 'false');
    }

    // Hover opens the menu, but hover never closes it — closing is
    // always user intent (click outside, Escape, or click trigger again).
    // The original code closed on `mouseleave`, which fires when the cursor
    // crosses the 8px gap between trigger and dropdown. That dead zone was
    // making the dropdown unreachable.
    devMenu.addEventListener('mouseenter', openDevMenu);

    // Open on focus (keyboard)
    dTrigger.addEventListener('focus', openDevMenu);
    dTrigger.addEventListener('click', (e) => {
      e.stopPropagation(); // don't let the outside-click handler immediately close
      if (devOpen) {
        closeDevMenu();
      } else {
        openDevMenu();
        // Focus first item
        const first = dDropdown.querySelector<HTMLElement>('.dev-menu__item');
        first?.focus();
      }
    });

    // Trap focus within dropdown when open
    dDropdown.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeDevMenu();
        dTrigger.focus();
      }
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!devMenu.contains(e.target as Node)) {
        closeDevMenu();
      }
    });

    // Close when focus leaves the menu
    devMenu.addEventListener('focusout', (e) => {
      if (!devMenu.contains(e.relatedTarget as Node)) {
        closeDevMenu();
      }
    });
  }
</script>
