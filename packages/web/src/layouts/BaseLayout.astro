---
import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/motifs.css';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description = 'Wyreup — 53 browser-native tools. No uploads. No signup.',
  ogTitle = title,
  ogDescription = description,
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFB000" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Wyreup" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content="https://wyreup.com/og-image.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Wyreup" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://wyreup.com/og-image.svg" />

    <title>{title}</title>

    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark" aria-current={currentPath === '/' ? 'page' : undefined}>wyreup</a>
        <nav class="site-nav" aria-label="Primary navigation">
          <a href="/tools" class="nav-link" aria-current={currentPath.startsWith('/tools') ? 'page' : undefined}>Tools</a>
          <a href="/cli" class="nav-link" aria-current={currentPath === '/cli' ? 'page' : undefined}>CLI</a>
          <a href="/skill" class="nav-link" aria-current={currentPath === '/skill' || currentPath === '/mcp' ? 'page' : undefined}>Agents</a>
          <a href="/about" class="nav-link" aria-current={currentPath === '/about' ? 'page' : undefined}>About</a>
          <a
            href="https://github.com/tamler/wyreup"
            class="nav-link nav-link--github"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wyreup on GitHub (opens in new tab)"
          >GitHub</a>
        </nav>
      </div>
    </header>

    <main class="site-main" id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-copy">&copy; {new Date().getFullYear()} Wyreup</span>
        <div class="footer-rule" aria-hidden="true">
          <span class="footer-rule__line"></span>
          <span class="footer-rule__pad"></span>
        </div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <a href="https://github.com/tamler/wyreup" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
          <a href="/settings" class="footer-link">Settings</a>
          <a href="/sitemap.xml" class="footer-link">Sitemap</a>
        </nav>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    height: 48px;
    display: flex;
    align-items: center;
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 100%;
    width: 100%;
  }

  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    text-decoration: none;
    justify-self: start;
  }

  .wordmark:hover {
    color: var(--accent);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    justify-self: center;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link[aria-current="page"] {
    color: var(--text-primary);
    border-bottom: 2px solid var(--accent);
    padding-bottom: 1px;
  }

  /* Main */
  .site-main {
    flex: 1;
    min-width: 0;
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-4) 0;
    margin-top: var(--space-12);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-subtle);
  }

  .footer-rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex: 1;
  }

  .footer-rule__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .footer-rule__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .footer-link:hover {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .header-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      height: auto;
      padding: var(--space-2) 0;
      gap: var(--space-1);
    }

    .site-header {
      height: auto;
    }

    .site-nav {
      gap: var(--space-3);
      justify-self: unset;
      flex-wrap: wrap;
    }

    .nav-link {
      font-size: var(--text-xs);
      /* Increase touch target size */
      padding: var(--space-1) 0;
      min-height: 36px;
      display: flex;
      align-items: center;
    }

    .nav-link--github {
      display: none;
    }
  }

  @media (max-width: 375px) {
    .site-nav {
      gap: var(--space-2);
    }
  }
</style>
