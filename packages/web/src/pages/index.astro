---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroDrop from '../components/HeroDrop.svelte';
import ScenarioGrid from '../components/ScenarioGrid.svelte';
import HowItWorks from '../components/HowItWorks.svelte';
import InstallCard from '../components/InstallCard.svelte';
import { createDefaultRegistry } from '@wyreup/core';

const registry = createDefaultRegistry();
const allTools = Array.from(registry.toolsById.values());

// Hand-curated popular tools (Deliverable 5)
const popularToolIds = ['compress', 'convert', 'merge-pdf', 'qr', 'face-blur', 'ocr', 'strip-exif', 'audio-enhance'];
const popularTools = popularToolIds.map((id) => {
  const t = allTools.find((tool) => tool.id === id);
  if (!t) {
    throw new Error(
      `Popular tool "${id}" not found in registry. ` +
        `Either rename in packages/web/src/pages/index.astro or remove from popularToolIds.`,
    );
  }
  return { id: t.id, name: t.name, category: t.category, description: t.description };
});
---

<BaseLayout
  title="Wyreup — File tools that run on your device."
  description="120+ privacy-first tools — compress, convert, transcribe, redact, caption, record. Browser, terminal, or AI agent. Nothing uploads. No signup."
  surfaceMode="welcome"
>
  <script is:inline>
    // Tool-first when installed: PWA users skip the marketing landing
    // and land directly on the tool grid. Browser visitors get the full
    // sell-what-it-is page. location.replace so the marketing page
    // never enters history (no back-button trap).
    if (typeof window !== 'undefined' && window.matchMedia('(display-mode: standalone)').matches) {
      window.location.replace('/tools');
    }
  </script>


  <!-- Section 1: Hero + drop zone -->
  <section class="hero section-rhythm" aria-label="Hero" id="hero-drop-zone">
    <div class="container hero__container">
      <!-- Left: value prop -->
      <div class="hero__copy">
        <h1 class="hero__headline">Tools for your files. <span class="hero__headline-accent">Nothing uploads.</span></h1>
        <p class="hero__body">
          Drop a file. We'll show you what you can do with it — compress, convert, transcribe, redact, and {allTools.length - 5}+ more. Everything happens on your device. No signup. No tracking.
        </p>
        <p class="hero__surfaces">
          Use Wyreup in your <a href="/" class="hero__surface-link" aria-current="page">browser</a>, your <a href="/cli" class="hero__surface-link">terminal</a>, or your <a href="/skill" class="hero__surface-link">AI assistant</a>.
        </p>
        <div class="hero__actions">
          <a href="/tools" class="btn btn-primary">Browse all tools &rarr;</a>
        </div>
      </div>

      <!-- Right: functional drop zone -->
      <div class="hero__drop-col">
        <HeroDrop client:load />
      </div>
    </div>

    <!-- Trust strip -->
    <div class="trust-strip" aria-label="Key facts">
      <div class="container trust-strip__inner">
        <span class="trust-stat">{allTools.length} tools</span>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-stat">0 uploads</span>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-stat">0 tracking</span>
        <span class="trust-sep" aria-hidden="true">·</span>
        <span class="trust-stat">MIT licensed</span>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 2: Scenarios / compatible tools -->
  <section class="scenarios section-rhythm" id="scenarios-section" aria-labelledby="scenarios-heading">
    <div class="container">
      <ScenarioGrid client:load />
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 3: How it works (live walkthrough — drop, pick, run) -->
  <section class="how section-rhythm" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <p class="section-sub">Drop a file, pick a tool, run it. No upload, no signup. Try it right here:</p>
      <HowItWorks client:load />
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 4: Use Wyreup anywhere -->
  <section class="anywhere section-rhythm" aria-labelledby="anywhere-heading">
    <div class="container">
      <h2 id="anywhere-heading" class="section-title">Use Wyreup anywhere.</h2>
      <div class="anywhere-grid">
        <a href="/tools" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Browser</div>
            <div class="anywhere-card__headline">wyreup.com</div>
            <p class="anywhere-card__body">No install. Start dropping files now.</p>
          </div>
        </a>
        <a href="/cli" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">CLI</div>
            <div class="anywhere-card__headline"><code>npx @wyreup/cli</code></div>
            <p class="anywhere-card__body">Shell-scriptable, batch-friendly, offline.</p>
          </div>
        </a>
        <a href="/skill" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Agent (MCP + skill)</div>
            <div class="anywhere-card__headline">For MCP clients</div>
            <p class="anywhere-card__body">Your files never leave your machine.</p>
          </div>
        </a>
        <InstallCard client:load />
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 5: Chain tools together -->
  <section class="chain-demo section-rhythm" aria-labelledby="chain-heading">
    <div class="container">
      <h2 id="chain-heading" class="section-title">Chain tools together.</h2>
      <p class="chain-body">
        Drop a file, pick a tool, see the result. Then pick another — the result becomes the next input. One drop, a cascade of outcomes. Every step runs on your device.
      </p>
      <p class="chain-bridge">
        Run a real chain: <a href="/chain/build" class="chain-bridge__link">build a pipeline at /chain/build</a>, drop a file, and every step runs on your device. <a href="/chain/build" class="chain-cta">Try it &rarr;</a>
      </p>
      <div class="chain-flow" aria-label="Chain demo: image.heic converted, then compressed to 247 KB JPG">
        <div class="chain-node chain-node--input" data-chain-index="0">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">image.heic</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node" data-chain-index="1">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">convert</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node" data-chain-index="2">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">compress</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node chain-node--output" data-chain-index="3">
          <div class="chain-node__inner">
            <span class="chain-node__dot chain-node__dot--active" aria-hidden="true"></span>
            <span class="chain-node__label">247 KB JPG</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 5b: Popular tools (Deliverable 5) -->
  <section class="popular section-rhythm" aria-labelledby="popular-heading">
    <div class="container">
      <h2 id="popular-heading" class="section-title">Popular tools</h2>
      <div class="popular-grid">
        {popularTools.map((tool) => (
          <a href={`/tools/${tool.id}`} class="popular-card" aria-label={`${tool.name} — ${tool.category}`}>
            <div class="popular-card__name">{tool.name}</div>
            <div class="popular-card__cat">{tool.category}</div>
            <p class="popular-card__desc">{tool.description}</p>
          </a>
        ))}
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 6: Privacy pitch — no viewport rhythm, natural tail -->
  <section class="privacy" aria-labelledby="privacy-heading">
    <div class="container">
      <div class="privacy-block">
        <h2 id="privacy-heading" class="privacy-block__title">No server. No data. No tradeoff.</h2>
        <p class="privacy-block__body">
          No analytics. No cookies. No server-side processing. Wyreup is MIT-licensed and open source — you can verify every line.
        </p>
        <a
          href="https://github.com/tamler/wyreup"
          class="privacy-block__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View source on GitHub &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Section rhythm (DESIGN.md §4) ──
     min-height was previously capped at 960px which left dead space
     below the bottom border + scroll hint on viewports taller than
     ~1100px (the next section started 100-400px below the visible
     fold, so the bottom border floated mid-screen). Use 100svh
     (small viewport height) — fills the viewport cleanly on every
     screen size, and 100svh accounts for mobile browser chrome
     (URL bar collapse) better than 100vh would. */
  .section-rhythm {
    min-height: max(640px, 100svh);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-block-start: clamp(96px, 14vh, 176px);
    padding-block-end: 80px;
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* Hero section centers its content vertically within the viewport. */
  .hero {
    justify-content: center;
    padding-block-start: clamp(48px, 8vh, 96px);
  }

  /* ── Hero ── */
  .hero__container {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-12);
    align-items: center;
    flex: 1;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__headline {
    font-family: var(--font-sans);
    font-size: var(--text-hero);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 var(--space-6);
    font-weight: 700;
  }

  .hero__headline-accent {
    color: var(--accent-text);
    display: inline;
  }

  .hero__body {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0 0 var(--space-4);
    max-width: 36rem;
  }

  .hero__body strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .hero__surfaces {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    margin: 0 0 var(--space-8);
    max-width: 520px;
    line-height: 1.6;
  }

  .hero__surface-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    text-underline-offset: 3px;
    transition: color var(--duration-instant) var(--ease-sharp), text-decoration-color var(--duration-instant) var(--ease-sharp);
  }

  .hero__surface-link[aria-current='page'] {
    color: var(--accent-text);
    text-decoration-color: var(--accent-text);
  }

  .hero__surface-link:hover {
    color: var(--text-primary);
    text-decoration-color: var(--text-primary);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__drop-col {
    display: flex;
    flex-direction: column;
    min-height: 280px;
  }

  /* ── Scenarios ── */
  .scenarios {
    background: var(--bg);
  }

  /* ── How it works ── */
  .how {
    background: var(--bg);
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
    color: var(--text-primary);
    font-family: var(--font-sans);
  }

  .section-sub {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--text-muted);
    margin: 0 0 var(--space-8);
    line-height: 1.5;
  }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .step {
    flex: 1;
    min-width: 0;
    padding: 0 var(--space-8);
  }

  .step:first-child {
    padding-left: 0;
  }

  .step:last-child {
    padding-right: 0;
  }

  .step__num {
    font-size: var(--text-2xl);
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .step__verb {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-sans);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .step__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    font-family: var(--font-sans);
  }

  /* Solder-pad connector: line ─── ■ ─── */
  .step__connector {
    display: flex;
    align-items: center;
    padding-top: 14px;
    flex-shrink: 0;
    width: 48px;
  }

  .connector-line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .connector-pad {
    display: block;
    width: 5px;
    height: 5px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ── Anywhere ── */
  .anywhere {
    background: var(--bg);
  }

  .anywhere-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  /* ── Chain demo ── */
  .chain-demo {
    background: var(--bg);
  }

  .chain-body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: var(--space-6);
  }

  .chain-bridge {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: var(--space-8);
  }

  .chain-bridge__link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .chain-bridge__link:hover {
    color: var(--accent-text);
  }

  .chain-cta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent-text);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .chain-cta:hover {
    color: var(--accent-hover);
  }

  .chain-flow {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: var(--space-4);
  }

  /* Each chain node starts hidden, then reveals on scroll */
  .chain-node {
    opacity: 0;
    transform: translateY(8px);
    animation: chain-reveal 150ms cubic-bezier(0, 0, 0.2, 1) forwards;
  }

  .chain-node[data-chain-index="0"] { animation-delay: 0ms; }
  .chain-node[data-chain-index="1"] { animation-delay: 400ms; }
  .chain-node[data-chain-index="2"] { animation-delay: 800ms; }
  .chain-node[data-chain-index="3"] { animation-delay: 1200ms; }

  @keyframes chain-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chain-node__inner {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    white-space: nowrap;
  }

  .chain-node--output .chain-node__inner {
    border-color: var(--accent-hover);
    background: var(--accent-dim);
  }

  .chain-node__dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    flex-shrink: 0;
  }

  .chain-node__dot--active {
    border-color: var(--accent-hover);
    background: var(--accent);
  }

  .chain-node__label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 500;
  }

  .chain-node--output .chain-node__label {
    color: var(--accent-text);
  }

  .chain-arrow {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--border);
    flex-shrink: 0;
    position: relative;
  }

  .chain-arrow::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-right: 1px solid var(--border);
    border-top: 1px solid var(--border);
    rotate: 45deg;
  }

  /* ── Popular tools (Deliverable 5) ── */
  .popular {
    background: var(--bg);
  }

  .popular-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  .popular-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-sharp);
  }

  .popular-card:hover {
    border-color: var(--text-muted);
  }

  .popular-card:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: 2px;
  }

  .popular-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .popular-card__cat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .popular-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Privacy ── */
  .privacy {
    padding: var(--space-16) 0;
  }

  .privacy-block {
    max-width: 560px;
  }

  .privacy-block__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__link {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-subtle);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .privacy-block__link:hover {
    color: var(--text-muted);
  }

  /* ── Trust strip ── */
  .trust-strip {
    margin-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-4);
  }

  .trust-strip__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .trust-stat {
    font-family: var(--font-sans);
