---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroDrop from '../components/HeroDrop.svelte';
import ScenarioGrid from '../components/ScenarioGrid.svelte';
import InstallCard from '../components/InstallCard.svelte';
---

<BaseLayout
  title="Wyreup — Privacy and productivity. Have both."
  description="52 browser-side tools for images, PDFs, text, and code. Everything runs on your device. Your files never upload, never cache, never phone home."
>
  <!-- Section 1: Hero + drop zone -->
  <section class="hero section-rhythm" aria-label="Hero">
    <div class="container hero__container">
      <!-- Left: value prop -->
      <div class="hero__copy">
        <h1 class="hero__headline">Privacy and productivity.<br>Have both.</h1>
        <p class="hero__body">
          52 browser-side tools for images, PDFs, text, and code.
          Everything runs on your device. Your files never upload, never cache, never phone home.
        </p>
        <div class="hero__actions">
          <a href="/tools" class="btn btn-primary">Browse tools &rarr;</a>
        </div>
      </div>

      <!-- Right: functional drop zone -->
      <div class="hero__drop-col">
        <HeroDrop client:load />
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 2: Scenarios / compatible tools -->
  <section class="scenarios section-rhythm" id="scenarios-section" aria-labelledby="scenarios-heading">
    <div class="container">
      <ScenarioGrid client:load />
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 3: How it works -->
  <section class="how section-rhythm" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <div class="steps-row">
        <div class="step">
          <div class="step__num">01</div>
          <div class="step__verb">Drop.</div>
          <p class="step__body">Open any tool and drop your file directly into the browser.</p>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="connector-line"></span>
          <span class="connector-pad"></span>
          <span class="connector-line"></span>
        </div>
        <div class="step">
          <div class="step__num">02</div>
          <div class="step__verb">Pick.</div>
          <p class="step__body">Choose your settings. Processing runs entirely on-device.</p>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="connector-line"></span>
          <span class="connector-pad"></span>
          <span class="connector-line"></span>
        </div>
        <div class="step">
          <div class="step__num">03</div>
          <div class="step__verb">Download.</div>
          <p class="step__body">Get the result instantly. Nothing touched a server.</p>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 4: Use Wyreup anywhere -->
  <section class="anywhere section-rhythm" aria-labelledby="anywhere-heading">
    <div class="container">
      <h2 id="anywhere-heading" class="section-title">Use Wyreup anywhere.</h2>
      <div class="anywhere-grid">
        <a href="/tools" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Browser</div>
            <div class="anywhere-card__headline">wyreup.com</div>
            <p class="anywhere-card__body">No install. Start dropping files now.</p>
          </div>
        </a>
        <a href="/cli" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">CLI</div>
            <div class="anywhere-card__headline"><code>npx @wyreup/cli</code></div>
            <p class="anywhere-card__body">Shell-scriptable, batch-friendly, offline.</p>
          </div>
        </a>
        <a href="/skill" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Agent (MCP + skill)</div>
            <div class="anywhere-card__headline">Claude integration</div>
            <p class="anywhere-card__body">Your files never leave your machine.</p>
          </div>
        </a>
        <InstallCard client:load />
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="scroll-hint" aria-hidden="true">
      <span class="scroll-hint__line"></span>
      <span class="scroll-hint__pad"></span>
      <span class="scroll-hint__label">scroll</span>
      <span class="scroll-hint__chevron">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </span>
    </div>
  </section>

  <!-- Section 5: Privacy pitch — no viewport rhythm, natural tail -->
  <section class="privacy" aria-labelledby="privacy-heading">
    <div class="container">
      <div class="privacy-block">
        <h2 id="privacy-heading" class="privacy-block__title">No server. No data. No tradeoff.</h2>
        <p class="privacy-block__body">
          No analytics. No cookies. No server-side processing. Wyreup is MIT-licensed and open source — you can verify every line.
        </p>
        <a
          href="https://github.com/tamler/wyreup"
          class="privacy-block__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View source on GitHub &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Section rhythm (DESIGN.md §4) ── */
  .section-rhythm {
    min-height: clamp(640px, 90vh, 960px);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-block-start: clamp(96px, 14vh, 176px);
    padding-block-end: 80px;
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ── Hero ── */
  .hero__container {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-12);
    align-items: start;
    flex: 1;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__headline {
    font-size: var(--text-hero);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .hero__body {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: var(--space-8);
    font-family: var(--font-sans);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__drop-col {
    display: flex;
    flex-direction: column;
    min-height: 280px;
  }

  /* ── Scenarios ── */
  .scenarios {
    background: var(--bg);
  }

  /* ── How it works ── */
  .how {
    background: var(--bg);
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-12);
    color: var(--text-primary);
    font-family: var(--font-sans);
  }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .step {
    flex: 1;
    min-width: 0;
    padding: 0 var(--space-8);
  }

  .step:first-child {
    padding-left: 0;
  }

  .step:last-child {
    padding-right: 0;
  }

  .step__num {
    font-size: var(--text-2xl);
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .step__verb {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-sans);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .step__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    font-family: var(--font-sans);
  }

  /* Solder-pad connector: line ─── ■ ─── */
  .step__connector {
    display: flex;
    align-items: center;
    padding-top: 14px;
    flex-shrink: 0;
    width: 48px;
  }

  .connector-line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .connector-pad {
    display: block;
    width: 5px;
    height: 5px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ── Anywhere ── */
  .anywhere {
    background: var(--bg);
  }

  .anywhere-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  .anywhere-card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1px;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-sharp);
    position: relative;
    overflow: visible;
  }

  .anywhere-card:hover {
    border-color: var(--text-muted);
  }

  .anywhere-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .anywhere-card__inner {
    background: var(--bg-raised);
    border: 1px solid var(--border-subtle);
    border-radius: calc(var(--radius-md) - 1px);
    padding: var(--space-6);
    height: 100%;
  }

  .anywhere-card__channel {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }

  .anywhere-card__headline {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    line-height: 1.25;
  }

  .anywhere-card__headline code {
    font-family: var(--font-mono);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--accent);
  }

  .anywhere-card__body {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ── Privacy ── */
  .privacy {
    padding: var(--space-16) 0;
  }

  .privacy-block {
    max-width: 560px;
  }

  .privacy-block__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__link {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-subtle);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .privacy-block__link:hover {
    color: var(--text-muted);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: var(--space-6);
    right: var(--space-8);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    animation: scroll-bob 2s linear infinite;
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }

  .scroll-hint__line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--border-subtle);
  }

  .scroll-hint__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .scroll-hint__label {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  .scroll-hint__chevron {
    display: flex;
    align-items: center;
    color: var(--accent);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero__container {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero__drop-col {
      min-height: 220px;
    }

    .steps-row {
      flex-direction: column;
      gap: var(--space-8);
    }

    .step__connector {
      display: none;
    }

    .step {
      padding: 0;
    }

    .anywhere-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .anywhere-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero__headline {
      font-size: var(--text-2xl);
    }

    .scroll-hint {
      right: var(--space-4);
    }

    .anywhere-grid {
      grid-template-columns: 1fr;
    }

    /* Tighter section rhythm on short/narrow mobile viewports */
    .section-rhythm {
      min-height: clamp(480px, 85vh, 960px);
      padding-block-start: clamp(48px, 10vh, 176px);
    }

    .hero__body {
      font-size: var(--text-base);
    }

    /* Tool card grid already goes single-column on mobile */
    /* Steps readable as-is since connectors are hidden */
    .step__verb {
      font-size: var(--text-md);
    }
  }

  @media (max-width: 375px) {
    .hero__headline {
      font-size: var(--text-xl);
    }

    .section-title {
      font-size: var(--text-xl);
    }
  }
</style>
