---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroDrop from '../components/HeroDrop.svelte';
import HeroSearch from '../components/HeroSearch.svelte';
import ScenarioGrid from '../components/ScenarioGrid.svelte';
import HowItWorks from '../components/HowItWorks.svelte';
import InstallCard from '../components/InstallCard.svelte';
import { createDefaultRegistry } from '@wyreup/core';

const registry = createDefaultRegistry();
const allTools = Array.from(registry.toolsById.values());
const localCount = allTools.filter((t) => t.cost !== 'credit').length;

// Hand-curated popular tools (Deliverable 5)
const popularToolIds = ['compress', 'convert', 'merge-pdf', 'qr', 'face-blur', 'ocr', 'strip-exif', 'audio-enhance'];
const popularTools = popularToolIds.map((id) => {
  const t = allTools.find((tool) => tool.id === id);
  if (!t) {
    throw new Error(
      `Popular tool "${id}" not found in registry. ` +
        `Either rename in packages/web/src/pages/index.astro or remove from popularToolIds.`,
    );
  }
  return { id: t.id, name: t.name, category: t.category, description: t.description };
});
---

<BaseLayout
  title="Wyreup — Drop a file. Get it ready for whatever comes next."
  description="Compress, convert, clean up, extract, understand, protect, and share files. Free tools run entirely on your device, no signup needed; hosted PRO tools say what they send."
  surfaceMode="welcome"
>
  <script is:inline>
    // Tool-first when installed: PWA users skip the marketing landing
    // and land directly on the tool grid. Browser visitors get the full
    // sell-what-it-is page. location.replace so the marketing page
    // never enters history (no back-button trap).
    if (typeof window !== 'undefined' && window.matchMedia('(display-mode: standalone)').matches) {
      window.location.replace('/tools');
    }
  </script>


  <!-- Section 1: Hero + drop zone -->
  <section class="hero section-rhythm" aria-label="Hero" id="hero-drop-zone">
    <div class="container hero__container">
      <!-- Left: value prop -->
      <div class="hero__copy">
        <h1 class="hero__headline">Drop a file. <span class="hero__headline-accent">Get it ready for whatever comes next.</span></h1>
        <p class="hero__body">
          Compress, convert, clean up, extract, understand, protect, share. Wyreup finds the right tool and keeps the work moving. Free tools run on your device; hosted PRO tools say so before anything is sent.
        </p>
        <HeroSearch client:load />
        <div class="hero__actions">
          <a href="/tools" class="btn btn-primary">Browse all tools &rarr;</a>
        </div>

        <!-- Trust facts stay with the value proposition so they support the
             hero instead of reading like a full-width page footer. -->
        <div class="trust-strip" aria-label="Key facts">
          <span class="trust-stat">{allTools.length} tools</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span class="trust-stat">{localCount} run fully on-device</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span class="trust-stat">0 tracking</span>
          <span class="trust-sep" aria-hidden="true">·</span>
          <span class="trust-stat">open source</span>
        </div>
      </div>

      <!-- Right: functional drop zone -->
      <div class="hero__drop-col">
        <HeroDrop client:load />
      </div>
    </div>
  </section>

  <!-- Section 2: Scenarios / compatible tools -->
  <section class="scenarios section-rhythm" id="scenarios-section" aria-labelledby="scenarios-heading">
    <div class="container">
      <ScenarioGrid client:load />
    </div>

  </section>

  <!-- Section 3: How it works (live walkthrough — drop, pick, run) -->
  <section class="how section-rhythm" id="how-section" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <p class="section-sub">Drop a file, pick a tool, run it. No signup — this demo runs right here on your device. Try it:</p>
      <HowItWorks client:load />
    </div>

  </section>

  <!-- Section 4: Chain tools together -->
  <section class="chain-demo section-rhythm" id="chains-section" aria-labelledby="chain-heading">
    <div class="container">
      <h2 id="chain-heading" class="section-title">Chain actions together.</h2>
      <p class="chain-body">
        Every result offers a next step — the output of one tool becomes the input of the next. Run a chain of actions once, save it with one click, and it is yours to rerun.
      </p>
      <a href="/chain/build" class="chain-cta">Build a chain &rarr;</a>
      <div class="chain-flow" aria-label="Chain demo: image.heic converted, then compressed to 247 KB JPG">
        <div class="chain-node chain-node--input" data-chain-index="0">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">image.heic</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node" data-chain-index="1">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">convert</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node" data-chain-index="2">
          <div class="chain-node__inner">
            <span class="chain-node__dot" aria-hidden="true"></span>
            <span class="chain-node__label">compress</span>
          </div>
        </div>
        <span class="chain-arrow" aria-hidden="true"></span>
        <div class="chain-node chain-node--output" data-chain-index="3">
          <div class="chain-node__inner">
            <span class="chain-node__dot chain-node__dot--active" aria-hidden="true"></span>
            <span class="chain-node__label">247 KB JPG</span>
          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- Section 5: Popular tools (Deliverable 5) -->
  <section class="popular section-rhythm" id="popular-section" aria-labelledby="popular-heading">
    <div class="container">
      <h2 id="popular-heading" class="section-title">Popular tools</h2>
      <div class="popular-grid">
        {popularTools.map((tool) => (
          <a href={`/tools/${tool.id}`} class="popular-card" aria-label={`${tool.name} — ${tool.category}`}>
            <div class="popular-card__name">{tool.name}</div>
            <div class="popular-card__cat">{tool.category}</div>
            <p class="popular-card__desc">{tool.description}</p>
          </a>
        ))}
      </div>
    </div>

  </section>

  <!-- Section 6: PRO callout — bridge between the free tools and the
       monetized tier. Short on purpose; full detail at /pro and
       /legal/pricing. -->
  <section class="pro-callout section-rhythm" id="pro-section" aria-labelledby="pro-callout-heading">
    <div class="container">
      <div class="pro-block">
        <span class="pro-block__chip">PRO</span>
        <h2 id="pro-callout-heading" class="pro-block__title">
          When the job needs more horsepower.
        </h2>
        <p class="pro-block__body">
          Higher-accuracy transcription for accents and noisy audio.
          Production-quality upscaling and background removal. Ask questions
          across a long PDF. Most cost just 1–2 credits. Packs start at
          <strong>220 credits for $5</strong> (never expire), or
          <strong>$8/mo for 440 credits</strong>. Failed runs auto-refund.
        </p>
        <div class="pro-block__cta">
          <a href="/pro" class="pro-block__primary">See what PRO unlocks &rarr;</a>
          <a href="/pro#pricing" class="pro-block__secondary">Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 7: Use Wyreup anywhere -->
  <section class="anywhere section-rhythm" id="anywhere-section" aria-labelledby="anywhere-heading">
    <div class="container">
      <h2 id="anywhere-heading" class="section-title">Take Wyreup with you.</h2>
      <p class="section-sub">Like the workflow? Run the same tools from your terminal, hand them to your AI assistant, or install the app.</p>
      <div class="anywhere-grid">
        <a href="/tools" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Browser</div>
            <div class="anywhere-card__headline">wyreup.com</div>
            <p class="anywhere-card__body">You're already here. Keep dropping files.</p>
          </div>
        </a>
        <a href="/cli" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">Command line</div>
            <div class="anywhere-card__headline"><code>npx @wyreup/cli</code></div>
            <p class="anywhere-card__body">Shell-scriptable, batch-friendly, offline.</p>
          </div>
        </a>
        <a href="/skill" class="anywhere-card brackets">
          <div class="brackets-inner" aria-hidden="true"></div>
          <div class="anywhere-card__inner">
            <div class="anywhere-card__channel">AI assistants</div>
            <div class="anywhere-card__headline">Works with Claude and other MCP clients</div>
            <p class="anywhere-card__body">Free tools keep files on your machine.</p>
          </div>
        </a>
        <InstallCard client:load />
      </div>
    </div>

  </section>

  <!-- Section 8: Privacy pitch — no viewport rhythm, natural tail -->
  <section class="privacy" id="privacy-section" aria-labelledby="privacy-heading">
    <div class="container">
      <div class="privacy-block">
        <h2 id="privacy-heading" class="privacy-block__title">Private by default. No tradeoff.</h2>
        <p class="privacy-block__body">
          No analytics. No tracking cookies. Free tools run entirely on your device. Hosted PRO tools send your input over TLS, return the result, and keep nothing beyond a run record. Wyreup is open source — anyone can check how it works.
        </p>
        <a
          href="https://github.com/tamler/wyreup"
          class="privacy-block__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View source on GitHub &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Section rhythm (DESIGN.md §4) ── */
  .section-rhythm {
    padding-block: clamp(72px, 6vw, 96px);
    position: relative;
    border-bottom: 1px solid var(--border-subtle);
  }

  /* Content-fit hero leaves the next section visible without coupling the
     page rhythm to viewport height. */
  .hero {
    padding-block: clamp(48px, 7vh, 96px);
  }

  /* ── Hero ── */
  .hero__container {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero__headline {
    font-family: var(--font-sans);
    font-size: var(--text-hero);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 var(--space-6);
    font-weight: 700;
  }

  .hero__headline-accent {
    color: var(--accent-text);
    display: inline;
  }

  .hero__body {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0 0 var(--space-4);
    max-width: 36rem;
  }

  .hero__body strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__drop-col {
    display: flex;
    flex-direction: column;
    min-height: 360px;
  }

  /* Whole hero acts as a drop target — when files are dragged over any part
     of the hero section, tint the background to confirm the entire region
     accepts drops. The visible card has its own .dragover state too. */
  .hero.hero--dragover {
    background: var(--accent-dim);
    transition: background var(--duration-fast) var(--ease-sharp);
  }

  /* ── Scenarios ── */
  .scenarios {
    background: var(--bg);
  }

  /* ── How it works ── */
  .how {
    background: var(--bg);
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
    color: var(--text-primary);
    font-family: var(--font-sans);
  }

  .section-sub {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--text-muted);
    margin: 0 0 var(--space-8);
    line-height: 1.5;
  }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: 0;
  }

  .step {
    flex: 1;
    min-width: 0;
    padding: 0 var(--space-8);
  }

  .step:first-child {
    padding-left: 0;
  }

  .step:last-child {
    padding-right: 0;
  }

  .step__num {
    font-size: var(--text-2xl);
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
    line-height: 1;
  }

  .step__verb {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    font-family: var(--font-sans);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .step__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    font-family: var(--font-sans);
  }

  /* Solder-pad connector: line ─── ■ ─── */
  .step__connector {
    display: flex;
    align-items: center;
    padding-top: 14px;
    flex-shrink: 0;
    width: 48px;
  }

  .connector-line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .connector-pad {
    display: block;
    width: 5px;
    height: 5px;
    background: var(--border);
    flex-shrink: 0;
    margin: 0 2px;
  }

  /* ── Anywhere ── */
  .anywhere {
    background: var(--bg);
  }

  .anywhere-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }

  /* ── Chain demo ── */
  .chain-demo {
    background: var(--bg);
  }

  .chain-body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: var(--space-6);
  }

  .chain-cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--accent-text);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-bottom: var(--space-8);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .chain-cta:hover {
    color: var(--accent-hover);
  }

  .chain-flow {
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
    row-gap: var(--space-4);
  }

  /* Each chain node starts hidden, then reveals on scroll */
  .chain-node {
    opacity: 0;
    transform: translateY(8px);
    animation: chain-reveal 150ms cubic-bezier(0, 0, 0.2, 1) forwards;
  }

  .chain-node[data-chain-index="0"] { animation-delay: 0ms; }
  .chain-node[data-chain-index="1"] { animation-delay: 400ms; }
  .chain-node[data-chain-index="2"] { animation-delay: 800ms; }
  .chain-node[data-chain-index="3"] { animation-delay: 1200ms; }

  @keyframes chain-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chain-node__inner {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    white-space: nowrap;
  }

  .chain-node--output .chain-node__inner {
    border-color: var(--accent-hover);
    background: var(--accent-dim);
  }

  .chain-node__dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    flex-shrink: 0;
  }

  .chain-node__dot--active {
    border-color: var(--accent-hover);
    background: var(--accent);
  }

  .chain-node__label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    font-weight: 500;
  }

  .chain-node--output .chain-node__label {
    color: var(--accent-text);
  }

  .chain-arrow {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--border);
    flex-shrink: 0;
    position: relative;
  }

  .chain-arrow::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 4px;
    border-right: 1px solid var(--border);
    border-top: 1px solid var(--border);
    rotate: 45deg;
  }

  /* ── Popular tools (Deliverable 5) ── */
  .popular {
    background: var(--bg);
  }

  .popular-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
  }

  .popular-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-sharp);
  }

  .popular-card:hover {
    border-color: var(--text-muted);
  }

  .popular-card:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: 2px;
  }

  .popular-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .popular-card__cat {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .popular-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Privacy ── */
  /* ── PRO callout ── */
  .pro-callout {
    border-top: 1px solid var(--border-subtle);
  }

  .pro-block {
    max-width: 640px;
  }

  .pro-block__chip {
    display: inline-block;
    background: var(--accent);
    color: var(--text-on-accent, #000);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--space-3);
  }

  .pro-block__title {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
  }

  .pro-block__body {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 var(--space-4);
  }

  .pro-block__body strong {
    color: var(--text-primary);
  }

  .pro-block__cta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .pro-block__primary {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background: var(--accent);
    color: var(--black);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--duration-instant) var(--ease-sharp);
  }

  .pro-block__primary:hover {
    background: var(--accent-hover);
  }

  .pro-block__secondary {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .pro-block__secondary:hover {
    color: var(--text-primary);
  }

  .privacy {
    padding: var(--space-16) 0;
  }

  .privacy-block {
    max-width: 560px;
  }

  .privacy-block__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__link {
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    color: var(--text-subtle);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .privacy-block__link:hover {
    color: var(--text-muted);
  }

  /* ── Trust strip ── */
  .trust-strip {
    margin-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    max-width: 36rem;
  }

  .trust-stat {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    letter-spacing: 0;
  }

  .trust-sep {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--border);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .trust-strip {
      gap: var(--space-3);
    }

    .trust-stat {
      font-size: var(--text-xs);
    }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero__container {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero__drop-col {
      min-height: 220px;
    }

    .steps-row {
      flex-direction: column;
      gap: var(--space-8);
    }

    .step__connector {
      display: none;
    }

    .step {
      padding: 0;
    }

    .anywhere-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .popular-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .anywhere-grid {
