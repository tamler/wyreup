---
import BaseLayout from '../layouts/BaseLayout.astro';

// Inline SVG icons per category (20px, 1.5px stroke, Lucide-style)
const categoryIcons: Record<string, string> = {
  optimize: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>`,
  convert: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3l4 4-4 4"/><path d="M3 7h18"/><path d="M7 21l-4-4 4-4"/><path d="M21 17H3"/></svg>`,
  pdf: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  inspect: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  create: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>`,
  privacy: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  extract: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  text: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
};

const scenarios = [
  {
    label: 'Compress a photo for email',
    tool: 'compress',
    category: 'optimize',
    slug: 'compress',
  },
  {
    label: 'Merge receipts into one PDF',
    tool: 'merge-pdf',
    category: 'pdf',
    slug: 'merge-pdf',
  },
  {
    label: 'Blur strangers from a vacation photo',
    tool: 'face-blur',
    category: 'privacy',
    slug: 'face-blur',
  },
  {
    label: 'Extract text from a scan',
    tool: 'ocr',
    category: 'extract',
    slug: 'ocr',
  },
];
---

<BaseLayout
  title="Wyreup — Privacy and productivity. Have both."
  description="52 browser-side tools for images, PDFs, text, and code. Everything runs on your device. Your files never upload, never cache, never phone home."
>
  <!-- Section 1: Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__headline">Privacy and productivity.<br>Have both.</h1>
      <p class="hero__body">
        Compress, convert, merge, blur, extract — 52 browser-side tools for images, PDFs, text, and code.
        Everything runs on your device. Your files never upload, never cache, never phone home.
      </p>
      <div class="hero__actions">
        <a href="/tools" class="btn btn-primary">Browse tools &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Section 2: Scenarios — "Do X, Y, Z. Right now." -->
  <section class="scenarios" aria-labelledby="scenarios-heading">
    <div class="container">
      <p class="scenarios__eyebrow">What can you do here, right now?</p>
      <div class="scenarios-bento" id="scenarios-grid">
        {scenarios.map((s, i) => (
          <a
            href={`/tools/${s.slug}`}
            class="scenario-card brackets"
            style={`--stagger-delay: ${i * 50}ms`}
            aria-label={s.label}
          >
            <div class="brackets-inner" aria-hidden="true"></div>
            <div class="scenario-card__inner">
              <span class="scenario-card__icon" set:html={categoryIcons[s.category] ?? categoryIcons.extract}></span>
              <div class="scenario-card__label">{s.label}</div>
              <div class="scenario-card__tool">{s.tool}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 3: How it works -->
  <section class="how" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <div class="steps-row">
        <div class="step">
          <div class="step__num">01</div>
          <div class="step__verb">Drop.</div>
          <p class="step__body">Open any tool and drop your file directly into the browser.</p>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="step__line"></span>
          <span class="step__pad"></span>
        </div>
        <div class="step">
          <div class="step__num">02</div>
          <div class="step__verb">Pick.</div>
          <p class="step__body">Choose your settings. Processing runs entirely on-device.</p>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="step__line"></span>
          <span class="step__pad"></span>
        </div>
        <div class="step">
          <div class="step__num">03</div>
          <div class="step__verb">Download.</div>
          <p class="step__body">Get the result instantly. Nothing touched a server.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Privacy pitch -->
  <section class="privacy" aria-labelledby="privacy-heading">
    <div class="container">
      <div class="privacy-block">
        <h2 id="privacy-heading" class="privacy-block__title">No server. No data. No tradeoff.</h2>
        <p class="privacy-block__body">
          No analytics. No cookies. No server-side processing. Wyreup is MIT-licensed and open source — you can verify every line.
        </p>
        <a
          href="https://github.com/wyreup/wyreup"
          class="privacy-block__link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View source on GitHub &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Section spacing token ── */
  :root {
    --space-section: 96px;
  }

  /* ── Hero ── */
  .hero {
    padding: var(--space-section) 0 72px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero__headline {
    font-size: var(--text-hero);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    max-width: 640px;
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  .hero__body {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: var(--space-8);
    font-family: var(--font-sans);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* ── Scenarios ── */
  .scenarios {
    padding: var(--space-section) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .scenarios__eyebrow {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-6);
  }

  /* Bento: 2 wide on top, 2 narrower on bottom */
  .scenarios-bento {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-4);
  }

  /* Staggered reveal — cards start invisible, animate in on load */
  .scenario-card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: visible;
    transition: border-color var(--duration-fast) var(--ease-sharp);
    /* stagger reveal */
    opacity: 0;
    transform: translateY(8px);
    animation: card-reveal var(--duration-base) var(--ease-out) forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  @keyframes card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scenario-card:hover {
    border-color: var(--text-muted);
  }

  .scenario-card:hover .scenario-card__icon {
    color: var(--accent);
  }

  .scenario-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .scenario-card__inner {
    background: var(--bg-raised);
    border: 1px solid var(--border-subtle);
    border-radius: calc(var(--radius-md) - 1px);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }

  .scenario-card__icon {
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-sharp),
                transform var(--duration-base) var(--ease-out);
    display: flex;
    align-items: center;
    width: 20px;
    height: 20px;
    /* magnetic pull target */
    transform: translate(calc(var(--pull-x, 0) * 1px), calc(var(--pull-y, 0) * 1px));
  }

  .scenario-card__label {
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.35;
    font-family: var(--font-sans);
  }

  .scenario-card__tool {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: auto;
  }

  /* ── How it works ── */
  .how {
    padding: var(--space-section) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-8);
    color: var(--text-primary);
  }

  .steps-row {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    flex-wrap: nowrap;
  }

  .step {
    flex: 1;
    min-width: 0;
  }

  .step__num {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .step__verb {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-sans);
    margin-bottom: var(--space-2);
  }

  .step__body {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
    font-family: var(--font-sans);
  }

  .step__connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 28px;
    gap: var(--space-1);
    flex-shrink: 0;
    width: 40px;
  }

  .step__line {
    display: block;
    width: 1px;
    flex: 1;
    min-height: 24px;
    background: var(--border-subtle);
  }

  .step__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Privacy ── */
  .privacy {
    padding: var(--space-section) 0;
  }

  .privacy-block {
    max-width: 560px;
  }

  .privacy-block__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .privacy-block__link {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-subtle);
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .privacy-block__link:hover {
    color: var(--text-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .steps-row {
      flex-wrap: wrap;
    }

    .step__connector {
      display: none;
    }
  }

  @media (max-width: 640px) {
    :root {
      --space-section: 64px;
    }

    .hero {
      padding: 64px 0 48px;
    }

    .hero__headline {
      font-size: var(--text-2xl);
    }

    .scenarios-bento {
      grid-template-columns: 1fr;
    }

    .steps-row {
      flex-direction: column;
    }
  }
</style>

<script>
  // Magnetic pull on scenario card icons
  const cards = document.querySelectorAll<HTMLElement>('.scenario-card');

  cards.forEach((card) => {
    const icon = card.querySelector<HTMLElement>('.scenario-card__icon');
    if (!icon) return;

    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      // Raw delta from center, capped to ±3px
      const dx = Math.max(-3, Math.min(3, (e.clientX - cx) * 0.06));
      const dy = Math.max(-3, Math.min(3, (e.clientY - cy) * 0.06));
      icon.style.setProperty('--pull-x', String(dx));
      icon.style.setProperty('--pull-y', String(dy));
    });

    card.addEventListener('mouseleave', () => {
      icon.style.setProperty('--pull-x', '0');
      icon.style.setProperty('--pull-y', '0');
    });
  });
</script>
