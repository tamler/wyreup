---
import BaseLayout from '../layouts/BaseLayout.astro';

// Inline SVG icons per category — 20px, 1.5px stroke, Lucide-style
const categoryIcons: Record<string, string> = {
  optimize: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></svg>`,
  convert: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3l4 4-4 4"/><path d="M3 7h18"/><path d="M7 21l-4-4 4-4"/><path d="M21 17H3"/></svg>`,
  pdf: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  inspect: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  create: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>`,
  privacy: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  extract: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
  generate: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M5.34 5.34L3.93 6.75M19.07 19.07l-1.41-1.41M5.34 18.66l-1.41 1.41M12 2v2M12 20v2M2 12h2M20 12h2"/></svg>`,
  text: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>`,
  dev: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  image: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>`,
  'export': `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
  'edit': `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
};

const defaultIcon = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>`;

const featuredTools = [
  {
    id: 'compress',
    name: 'Compress',
    category: 'optimize',
    description: 'Reduce image file size by re-encoding at a lower quality.',
  },
  {
    id: 'convert',
    name: 'Convert format',
    category: 'convert',
    description: 'Convert images between JPEG, PNG, and WebP formats.',
  },
  {
    id: 'merge-pdf',
    name: 'Merge PDFs',
    category: 'pdf',
    description: 'Combine multiple PDF files into a single document.',
  },
  {
    id: 'hash',
    name: 'Hash',
    category: 'inspect',
    description: 'Compute SHA-256, SHA-1, or SHA-512 hashes of files.',
  },
  {
    id: 'qr',
    name: 'QR Code',
    category: 'create',
    description: 'Generate a QR code image from text or a URL.',
  },
  {
    id: 'face-blur',
    name: 'Face Blur',
    category: 'privacy',
    description: 'Automatically detect and blur faces in images.',
  },
];
---

<BaseLayout
  title="Wyreup — 52 browser tools, zero uploads"
  description="Your files stay on your device. 52 tools. Zero signup. Compress, convert, redact, extract — all in your browser."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1 class="hero__headline">Your files stay on your device.<br />52 tools. Zero signup.</h1>
      <p class="hero__body">Compress, convert, redact, extract. Every tool runs in your browser — nothing uploads.</p>
      <div class="hero__actions">
        <a href="/tools" class="btn btn-primary">Browse tools &rarr;</a>
        <a href="/cli" class="btn btn-secondary">Install CLI</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats" aria-label="Key facts">
    <div class="container">
      <div class="stats-row">
        <div class="solder-stat">
          <span class="solder-stat__line" aria-hidden="true"></span>
          <span class="solder-stat__pad" aria-hidden="true"></span>
          <span class="solder-stat__text">52 tools</span>
        </div>
        <div class="solder-stat">
          <span class="solder-stat__line" aria-hidden="true"></span>
          <span class="solder-stat__pad" aria-hidden="true"></span>
          <span class="solder-stat__text">0 uploads</span>
        </div>
        <div class="solder-stat">
          <span class="solder-stat__line" aria-hidden="true"></span>
          <span class="solder-stat__pad" aria-hidden="true"></span>
          <span class="solder-stat__text">MIT licensed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured tools -->
  <section class="featured" aria-labelledby="featured-heading">
    <div class="container">
      <h2 id="featured-heading" class="section-title">Featured tools</h2>
      <div class="tool-grid">
        {featuredTools.map((tool) => (
          <a href={`/tools/${tool.id}`} class="tool-card brackets" aria-label={tool.name}>
            <div class="brackets-inner">
              <div class="tool-card__header">
                <span class="tool-card__icon" set:html={categoryIcons[tool.category] ?? defaultIcon}></span>
                <div>
                  <div class="tool-card__name">{tool.name}</div>
                  <div class="tool-card__category">{tool.category}</div>
                </div>
              </div>
              <div class="tool-card__divider" aria-hidden="true"></div>
              <p class="tool-card__desc">{tool.description}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="featured__cta">
        <a href="/tools" class="btn btn-secondary">View all 52 tools &rarr;</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how" aria-labelledby="how-heading">
    <div class="container">
      <h2 id="how-heading" class="section-title">How it works</h2>
      <div class="steps-row">
        <div class="step">
          <div class="step__num">01</div>
          <div class="step__label">Drop file.</div>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="step__line"></span>
          <span class="step__pad"></span>
        </div>
        <div class="step">
          <div class="step__num">02</div>
          <div class="step__label">Pick tool.</div>
        </div>
        <div class="step__connector" aria-hidden="true">
          <span class="step__line"></span>
          <span class="step__pad"></span>
        </div>
        <div class="step">
          <div class="step__num">03</div>
          <div class="step__label">Download result.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy pitch -->
  <section class="privacy" aria-labelledby="privacy-heading">
    <div class="container">
      <div class="privacy-block">
        <h2 id="privacy-heading" class="privacy-block__title">No server. No data.</h2>
        <p class="privacy-block__body">
          Every tool runs locally in your browser using WebAssembly and the Web APIs your device already has.
          Files never leave your machine. No analytics. No cookies. No server-side processing.
          The CLI is available for automation — it shares the same engine, offline.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: var(--space-12) 0 var(--space-8);
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero__headline {
    font-size: var(--text-hero);
    line-height: 1.1;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: var(--text-primary);
    max-width: 680px;
    margin-bottom: var(--space-4);
  }

  .hero__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 520px;
    margin-bottom: var(--space-6);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Stats */
  .stats {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .stats-row {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  /* Section title */
  .section-title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-6);
    color: var(--text-primary);
  }

  /* Featured tools */
  .featured {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .tool-card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--duration-fast) var(--ease-sharp),
      background var(--duration-fast) var(--ease-sharp);
    position: relative;
  }

  .tool-card:hover {
    border-color: var(--text-muted);
    background: var(--bg-raised);
  }

  .tool-card:hover .tool-card__icon {
    color: var(--accent);
  }

  .tool-card__header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .tool-card__icon {
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-sharp);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    width: 20px;
    height: 20px;
  }

  .tool-card__name {
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .tool-card__category {
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--space-1);
  }

  .tool-card__divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: var(--space-3);
  }

  .tool-card__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured__cta {
    display: flex;
  }

  /* How it works */
  .how {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .steps-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .step {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .step__num {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
  }

  .step__label {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
  }

  .step__connector {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1;
    min-width: 40px;
  }

  .step__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .step__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Privacy */
  .privacy {
    padding: var(--space-8) 0;
  }

  .privacy-block {
    max-width: 640px;
  }

  .privacy-block__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-3);
    color: var(--text-primary);
  }

  .privacy-block__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero__headline {
      font-size: var(--text-2xl);
    }

    .tool-grid {
      grid-template-columns: 1fr;
    }

    .steps-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .step__connector {
      display: none;
    }
  }
</style>
