---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProBadge from '../components/ProBadge.svelte';
import ProSignup from '../components/ProSignup.svelte';

// Pro tool catalog, grouped for the page. Credit costs mirror the
// server-authoritative table in functions/_lib/pricing.ts.
const catalog = [
  {
    group: 'Document & image reading',
    tools: [
      { name: 'OCR', desc: 'Pull text out of photos, screenshots, and scans.', cost: 1 },
      { name: 'Read handwriting', desc: 'Transcribe handwritten notes and forms.', cost: 1 },
      { name: 'Describe image', desc: 'Plain-language alt-text for any image.', cost: 1 },
      { name: 'Analyze chart', desc: 'Read a chart or graph and explain the data.', cost: 1 },
      { name: 'Ask about an image', desc: 'Ask a question, get an answer from the picture.', cost: 1 },
      { name: 'Detect objects', desc: 'Find and label objects, with bounding boxes.', cost: 1 },
      { name: 'Translate image text', desc: 'Photograph foreign text, get the translation.', cost: 2 },
    ],
  },
  {
    group: 'Audio',
    tools: [
      { name: 'Transcribe', desc: 'Large-model transcription — accurate on noisy, accented speech.', cost: 3 },
      { name: 'Transcribe & translate', desc: 'Audio in, translated transcript out, one step.', cost: 5 },
    ],
  },
  {
    group: 'Text',
    tools: [
      { name: 'Summarize', desc: 'Tight summaries of long or messy text.', cost: 2 },
      { name: 'Translate', desc: 'High-quality translation, including rare language pairs.', cost: 2 },
      { name: 'Redact PII', desc: 'Strip names, emails, and IDs — even free-form mentions.', cost: 2 },
      { name: 'Sentiment', desc: 'Tone classification that handles sarcasm and mixed signals.', cost: 1 },
      { name: 'Named entities', desc: 'Pull people, orgs, places, dates, and money.', cost: 1 },
    ],
  },
  {
    group: 'Image editing',
    tools: [
      { name: 'Background remove', desc: 'Clean cutouts — hair, glass, fine detail.', cost: 3 },
      { name: 'Upscale', desc: 'Sharpen and enlarge images 2× or 4×.', cost: 3 },
    ],
  },
];

const packs = [
  { credits: 150, price: '$5', note: 'Starter' },
  { credits: 330, price: '$10', note: 'Best value', featured: true },
  { credits: 680, price: '$20', note: 'Power' },
];

const why = [
  { h: 'Free stays free', p: 'Every in-browser tool — compression, PDF, image, audio, code & data helpers — stays free, no account, no upload, no tracking.' },
  { h: 'Failed runs auto-refund', p: 'If a hosted model errors, the credits go straight back to your balance. No ticket, no waiting.' },
  { h: 'Same privacy posture', p: "We don't keep your inputs or outputs after a PRO run — only which tool ran, for your own history." },
  { h: 'One key, everywhere', p: 'Browser, CLI, and AI agents (MCP) all draw from the same balance with the same key.' },
];
---

<BaseLayout
  title="Wyreup PRO — hosted-AI tools, pay only for what you run"
  description="Sign up free in one step. PRO unlocks OCR, transcription, translation, image understanding and more — most tools cost 1–2 credits. Packs from $5, or $8/mo."
>
  <!-- Hero -->
  <section class="pro-section pro-hero">
    <div class="container hero__inner">
      <div class="hero__chip"><ProBadge /><span>Wyreup PRO</span></div>
      <h1 class="hero__title">Hosted-AI tools.<br />Pay only for what you run.</h1>
      <p class="hero__sub">
        Every tool that runs in your browser is free, forever. PRO adds the
        AI tools that need real servers — OCR, transcription, translation,
        image understanding. Most cost 1–2 credits a run; failed runs
        refund automatically.
      </p>
      <p class="hero__price">
        Packs from <strong>$5</strong> · or <strong>$8/mo</strong> · credits never expire
      </p>
      <div class="hero__cta">
        <a href="#signup" class="btn-primary">Start free — one step</a>
        <a href="#pricing" class="btn-ghost">See pricing</a>
      </div>
    </div>
  </section>

  <!-- Pricing — high on the page, nothing to hunt for -->
  <section class="pro-section pro-section--tint" id="pricing">
    <div class="container">
      <h2 class="section-title">Simple credit pricing</h2>
      <p class="section-sub">
        Buy a pack once — credits never expire — or subscribe monthly. Most
        tools cost 1–2 credits, so a starter pack covers roughly 150 image
        reads, 75 text jobs, or 50 transcriptions.
      </p>

      <div class="packs">
        {packs.map((p) => (
          <div class={`pack${p.featured ? ' pack--featured' : ''}`}>
            <span class="pack__note">{p.note}</span>
            <div class="pack__credits">{p.credits}</div>
            <div class="pack__label">credits</div>
            <div class="pack__price">{p.price}</div>
          </div>
        ))}
        <div class="pack pack--monthly">
          <span class="pack__note">Monthly</span>
          <div class="pack__credits">300</div>
          <div class="pack__label">credits / month</div>
          <div class="pack__price">$8<span class="pack__per">/mo</span></div>
        </div>
      </div>

      <p class="pricing-fine">
        Pack credits never expire. The monthly plan grants 300 credits each
        cycle into the same balance; cancel anytime. Once you're signed in,
        buy from your account in two clicks. Payment is handled by Lemon
        Squeezy — we never see your card.
      </p>
    </div>
  </section>

  <!-- Signup -->
  <section class="pro-section" id="signup">
    <div class="container">
      <h2 class="section-title">Start free in one step</h2>
      <p class="section-sub">
        No password, no card. Enter your email and you're signed in — you
        only pay if you choose to buy credits.
      </p>
      <ProSignup client:load />
    </div>
  </section>

  <!-- Catalog -->
  <section class="pro-section pro-section--tint">
    <div class="container">
      <h2 class="section-title">What PRO unlocks</h2>
      <p class="section-sub">Sixteen hosted-AI tools. Each shows its credit cost before you run it.</p>
      <div class="cat-grid">
        {catalog.map((g) => (
          <div class="cat-group">
            <h3 class="cat-group__name">{g.group}</h3>
            <ul class="cat-list">
              {g.tools.map((t) => (
                <li class="cat-item">
                  <div class="cat-item__main">
                    <span class="cat-item__name">{t.name}</span>
                    <span class="cat-item__desc">{t.desc}</span>
                  </div>
                  <span class="cat-item__cost">{t.cost} {t.cost === 1 ? 'credit' : 'credits'}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="pro-section">
    <div class="container">
      <h2 class="section-title">How it works</h2>
      <ol class="steps">
        <li class="step">
          <span class="step__num">1</span>
          <div>
            <span class="step__verb">Sign up</span>
            <p class="step__body">One field, instant — you're signed in right away.</p>
          </div>
        </li>
        <li class="step">
          <span class="step__num">2</span>
          <div>
            <span class="step__verb">Add credits</span>
            <p class="step__body">Pick a pack or the monthly plan. Lemon Squeezy handles payment; we never see your card.</p>
          </div>
        </li>
        <li class="step">
          <span class="step__num">3</span>
          <div>
            <span class="step__verb">Run any PRO tool</span>
            <p class="step__body">Each shows its credit cost up front. Credits deduct on success; failed runs refund automatically.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Why -->
  <section class="pro-section pro-section--tint">
    <div class="container">
      <h2 class="section-title">Built to be fair</h2>
      <div class="why-grid">
        {why.map((w) => (
          <div class="why-card">
            <h3>{w.h}</h3>
            <p>{w.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Self-host -->
  <section class="pro-section pro-section--last">
    <div class="container">
      <div class="self-host">
        <h2>Don't want a hosted tier at all?</h2>
        <p>
          Wyreup is MIT-licensed. Run <code>@wyreup/core</code> entirely on
          your own infrastructure. PRO exists because hosted AI inference
          has a real per-call cost — not because the free tools are limited.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Section rhythm — airy blocks with borders between, echoing the
     marketing pages without forcing a full viewport per section. */
  .pro-section {
    padding-block: clamp(56px, 8vh, 104px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .pro-section--tint {
    background: var(--bg-elevated);
  }
  .pro-section--last {
    border-bottom: none;
  }

  /* ── Hero ── */
  .pro-hero {
    padding-block: clamp(72px, 12vh, 152px);
  }
  .hero__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--space-5);
  }
  .hero__title {
    font-family: var(--font-sans);
    font-size: var(--text-3xl, 36px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.12;
    margin: 0 0 var(--space-5);
    color: var(--text-primary);
  }
  .hero__sub {
    max-width: 38rem;
    margin: 0 0 var(--space-4);
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
  }
  .hero__price {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    margin: 0 0 var(--space-6);
  }
  .hero__price strong {
    color: var(--text-primary);
  }
  .hero__cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  /* ── Shared section heading ── */
  .section-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 var(--space-3);
  }
  .section-sub {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.55;
    max-width: 42rem;
    margin: 0 0 var(--space-8);
  }

  /* ── Buttons ── */
  .btn-primary,
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--accent);
    color: var(--text-on-accent, #000);
    border-color: var(--accent);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
  }
  .btn-ghost {
    background: transparent;
    color: var(--text-primary);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    color: var(--accent-text);
  }

  /* ── Pricing ── */
  .packs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 860px) {
    .packs {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 460px) {
    .packs {
      grid-template-columns: 1fr;
    }
  }
  .pack {
    position: relative;
    padding: var(--space-6) var(--space-4);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .pro-section--tint .pack {
    background: var(--bg);
  }
  .pack--featured {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }
  .pack--monthly {
    border-color: var(--accent);
  }
  .pack__note {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: var(--space-3);
  }
  .pack--featured .pack__note {
    color: var(--accent-text);
  }
  .pack__credits {
    font-family: var(--font-mono);
    font-size: 38px;
    font-weight: 700;
    line-height: 1;
    color: var(--text-primary);
  }
  .pack__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: var(--space-1);
  }
  .pack__price {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
  }
  .pack__per {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-weight: 400;
  }
  .pricing-fine {
    max-width: 42rem;
    margin: var(--space-6) 0 0;
    font-size: var(--text-xs);
    color: var(--text-subtle);
    line-height: 1.6;
  }

  /* ── Catalog ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6) var(--space-8);
  }
  @media (max-width: 720px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
  .cat-group__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }
  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cat-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .cat-item:last-child {
    border-bottom: none;
  }
  .cat-item__main {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .cat-item__name {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }
  .cat-item__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.45;
  }
  .cat-item__cost {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-text);
    white-space: nowrap;
  }

  /* ── How it works ── */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 720px) {
    .steps {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
  .step {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .step__num {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent-text);
    line-height: 1;
    flex-shrink: 0;
  }
  .step__verb {
    display: block;
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }
  .step__body {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* ── Why ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 640px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
  .why-card {
    padding: var(--space-5);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .why-card h3 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
  }
  .why-card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* ── Self-host ── */
  .self-host {
    max-width: 42rem;
  }
  .self-host h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
  }
  .self-host p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }
  .self-host code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg-elevated);
    border-radius: var(--radius-sm);
    padding: 1px 4px;
  }
</style>
