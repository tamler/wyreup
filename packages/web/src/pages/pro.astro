---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProBadge from '../components/ProBadge.svelte';
import ProSignup from '../components/ProSignup.svelte';

// Pro tool catalog, grouped for the page. Credit costs mirror the
// server-authoritative table in functions/_lib/pricing.ts.
const catalog = [
  {
    group: 'Document & image reading',
    tools: [
      { name: 'OCR', desc: 'Pull text out of photos, screenshots, and scans.', cost: 1 },
      { name: 'Read handwriting', desc: 'Transcribe handwritten notes and forms.', cost: 1 },
      { name: 'Describe image', desc: 'Plain-language alt-text for any image.', cost: 1 },
      { name: 'Analyze chart', desc: 'Read a chart or graph and explain the data.', cost: 1 },
      { name: 'Ask about an image', desc: 'Ask a question, get an answer from the picture.', cost: 1 },
      { name: 'Detect objects', desc: 'Find and label objects, with bounding boxes.', cost: 1 },
      { name: 'Translate image text', desc: 'Photograph foreign text, get the translation.', cost: 2 },
    ],
  },
  {
    group: 'Audio',
    tools: [
      { name: 'Transcribe', desc: 'Large-model transcription — accurate on noisy, accented speech.', cost: 3 },
      { name: 'Transcribe & translate', desc: 'Audio in, translated transcript out, one step.', cost: 5 },
    ],
  },
  {
    group: 'Text',
    tools: [
      { name: 'Summarize', desc: 'Tight summaries of long or messy text.', cost: 2 },
      { name: 'Translate', desc: 'High-quality translation, including rare language pairs.', cost: 2 },
      { name: 'Redact PII', desc: 'Strip names, emails, and IDs — even free-form mentions.', cost: 2 },
      { name: 'Sentiment', desc: 'Tone classification that handles sarcasm and mixed signals.', cost: 1 },
      { name: 'Named entities', desc: 'Pull people, orgs, places, dates, and money.', cost: 1 },
    ],
  },
  {
    group: 'Image editing',
    tools: [
      { name: 'Background remove', desc: 'Clean cutouts — hair, glass, fine detail.', cost: 3 },
      { name: 'Upscale', desc: 'Sharpen and enlarge images 2× or 4×.', cost: 3 },
    ],
  },
];

const packs = [
  { credits: 150, price: '$5' },
  { credits: 330, price: '$10', featured: true },
  { credits: 680, price: '$20' },
];
---

<BaseLayout
  title="Wyreup PRO — hosted-AI tools, pay only for what you run"
  description="Sign up free in one step. PRO unlocks OCR, transcription, translation, image understanding and more — most tools cost 1–2 credits. Packs from $5, or $8/mo."
>
  <article class="pro">
    <!-- Hero -->
    <header class="hero">
      <div class="hero__chip"><ProBadge /><span>Wyreup PRO</span></div>
      <h1>Hosted-AI tools.<br />Pay only for what you run.</h1>
      <p class="hero__sub">
        Every tool that runs in your browser is free, forever. PRO adds the
        AI tools that need real servers — OCR, transcription, translation,
        image understanding. Most cost just 1–2 credits a run, and failed
        runs refund automatically.
      </p>
    </header>

    <!-- Signup — the one-step path -->
    <section class="signup-section">
      <ProSignup client:load />
      <p class="signup-note">
        Free to create. No password, no card. You only pay if you buy credits.
      </p>
    </section>

    <!-- Why -->
    <section class="why">
      <div class="why__card">
        <h2>Free stays free</h2>
        <p>Compression, PDF, image and audio tools, code &amp; data helpers — all in-browser, no account, no upload, no tracking.</p>
      </div>
      <div class="why__card">
        <h2>Failed runs auto-refund</h2>
        <p>If a hosted model errors, the credits go straight back to your balance. No ticket, no waiting.</p>
      </div>
      <div class="why__card">
        <h2>Same privacy posture</h2>
        <p>We don't keep your inputs or outputs after a PRO run. Only run metadata (which tool, when) for your history.</p>
      </div>
      <div class="why__card">
        <h2>One key, everywhere</h2>
        <p>Browser, CLI, and AI agents (MCP) all draw from the same balance with the same key.</p>
      </div>
    </section>

    <!-- Pricing -->
    <section class="pricing" id="pricing">
      <h2 class="section-title">Simple credit pricing</h2>
      <p class="section-lead">
        Buy a pack once (credits never expire) or subscribe monthly. Most
        tools cost 1–2 credits — a starter pack covers roughly 150 image
        reads, 75 text jobs, or 50 transcriptions.
      </p>

      <div class="packs">
        {packs.map((p) => (
          <div class={`pack${p.featured ? ' pack--featured' : ''}`}>
            {p.featured && <span class="pack__tag">Best value</span>}
            <div class="pack__credits">{p.credits}</div>
            <div class="pack__label">credits</div>
            <div class="pack__price">{p.price}</div>
          </div>
        ))}
      </div>
      <div class="packs packs--single">
        <div class="pack pack--monthly">
          <span class="pack__tag">Subscription</span>
          <div class="pack__credits">275</div>
          <div class="pack__label">credits / month</div>
          <div class="pack__price">$8 / mo</div>
        </div>
      </div>
      <p class="pricing-fine">
        Pack credits never expire. The monthly plan grants 275 credits each
        cycle into the same balance; cancel anytime. Buy from your account
        in two clicks once you're signed in.
      </p>
    </section>

    <!-- Catalog -->
    <section class="catalog">
      <h2 class="section-title">What PRO unlocks</h2>
      {catalog.map((g) => (
        <div class="cat-group">
          <h3 class="cat-group__name">{g.group}</h3>
          <ul class="cat-list">
            {g.tools.map((t) => (
              <li class="cat-item">
                <div class="cat-item__main">
                  <span class="cat-item__name">{t.name}</span>
                  <span class="cat-item__desc">{t.desc}</span>
                </div>
                <span class="cat-item__cost">{t.cost} {t.cost === 1 ? 'credit' : 'credits'}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <!-- How -->
    <section class="how">
      <h2 class="section-title">How it works</h2>
      <ol>
        <li><strong>Sign up.</strong> One field, instant — you're signed in right away.</li>
        <li><strong>Add credits.</strong> Pick a pack or the monthly plan. Payment is handled by Lemon Squeezy; we never see your card.</li>
        <li><strong>Run any PRO tool.</strong> Each shows its credit cost up front. Credits deduct on success; failed runs refund automatically.</li>
      </ol>
    </section>

    <!-- Self-host -->
    <section class="self-host">
      <h2>Don't want a hosted tier at all?</h2>
      <p>
        Wyreup is MIT-licensed. Run <code>@wyreup/core</code> entirely on your
        own infrastructure. PRO exists because hosted AI inference has a
        real per-call cost — not because the free tools are limited.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .pro {
    max-width: 880px;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4) var(--space-12);
    font-family: var(--font-sans);
    color: var(--text-primary);
  }

  .hero {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .hero__chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .hero h1 {
    font-size: var(--text-3xl, 36px);
    line-height: 1.15;
    margin: 0 0 var(--space-3);
  }
  .hero__sub {
    max-width: 600px;
    margin: 0 auto;
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.55;
  }

  .signup-section {
    margin-bottom: var(--space-10);
  }
  .signup-note {
    text-align: center;
    margin: var(--space-3) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .section-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0 0 var(--space-2);
    text-align: center;
  }
  .section-lead {
    max-width: 560px;
    margin: 0 auto var(--space-5);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .why {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-10);
  }
  @media (max-width: 640px) {
    .why {
      grid-template-columns: 1fr;
    }
  }
  .why__card {
    padding: var(--space-5);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .why__card h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-md);
    font-weight: 600;
  }
  .why__card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .pricing {
    margin-bottom: var(--space-10);
  }
  .packs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin: 0 0 var(--space-3);
  }
  .packs--single {
    grid-template-columns: minmax(0, 240px);
    justify-content: center;
  }
  @media (max-width: 560px) {
    .packs {
      grid-template-columns: 1fr;
    }
  }
  .pack {
    position: relative;
    padding: var(--space-5) var(--space-3);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .pack--featured,
  .pack--monthly {
    border-color: var(--accent);
  }
  .pack__tag {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: var(--text-on-accent, #000);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .pack__credits {
    font-family: var(--font-mono);
    font-size: 32px;
    font-weight: 600;
  }
  .pack__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .pack__price {
    margin-top: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-md);
  }
  .pricing-fine {
    max-width: 560px;
    margin: var(--space-4) auto 0;
    text-align: center;
    font-size: var(--text-xs);
    color: var(--text-subtle);
    line-height: 1.5;
  }

  .catalog {
    margin-bottom: var(--space-10);
  }
  .cat-group {
    margin-bottom: var(--space-5);
  }
  .cat-group__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin: 0 0 var(--space-2);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--border-subtle);
  }
  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cat-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) 0;
  }
  .cat-item__main {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cat-item__name {
    font-size: var(--text-sm);
    font-weight: 600;
  }
  .cat-item__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .cat-item__cost {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-text);
    white-space: nowrap;
  }

  .how {
    margin-bottom: var(--space-10);
  }
  .how ol {
    max-width: 600px;
    margin: 0 auto;
    padding-left: var(--space-5);
    color: var(--text-muted);
    line-height: 1.6;
    font-size: var(--text-sm);
  }
  .how li {
    margin-bottom: var(--space-2);
  }
  .how strong {
    color: var(--text-primary);
  }

  .self-host {
    padding: var(--space-5);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .self-host h2 {
    margin: 0 0 var(--space-2);
    font-size: var(--text-md);
    font-weight: 600;
  }
  .self-host p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
  }
  .self-host code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg);
    border-radius: var(--radius-sm);
    padding: 1px 4px;
  }
</style>
