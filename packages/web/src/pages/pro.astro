---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProBadge from '../components/ProBadge.svelte';
import ProSignup from '../components/ProSignup.svelte';
import { createDefaultRegistry } from '@wyreup/core';
import { PACKS, MONTHLY } from '../data/pricing';

// Catalog is derived from the registry — every tool with cost: 'credit'
// is a PRO tool. Grouping by credit cost is self-maintaining: add a PRO
// tool anywhere and it appears here at the right tier, no edit needed.
const registry = createDefaultRegistry();
const proTools = Array.from(registry.toolsById.values())
  .filter((t) => t.cost === 'credit')
  .map((t) => ({
    name: t.name.replace(/\s*\(PRO\)\s*$/i, ''),
    desc: t.description.replace(/\s*Uses \d+ credits? per run\.\s*$/i, '').trim(),
    cost: t.creditCost ?? 0,
  }));

const catalog = [...new Set(proTools.map((t) => t.cost))]
  .sort((a, b) => a - b)
  .map((cost) => ({
    cost,
    tools: proTools
      .filter((t) => t.cost === cost)
      .sort((a, b) => a.name.localeCompare(b.name)),
  }));

const starterPack = PACKS[0]!;

const why = [
  { h: 'Free stays free', p: 'Every in-browser tool — compression, PDF, image, audio, code & data helpers — stays free. No account, no upload, no tracking.' },
  { h: 'Failed runs auto-refund', p: 'If a hosted-AI tool errors, the credits return to your balance automatically. No ticket, no waiting.' },
  { h: 'Same privacy posture', p: "Inputs and outputs aren't kept after a PRO run — only which tool ran, for your own history." },
  { h: 'One key, everywhere', p: 'Browser, CLI, and AI agents draw from the same balance with the same key.' },
];
---

<BaseLayout
  surfaceMode="welcome"
  title="Wyreup PRO — hosted-AI tools, pay only for what you run"
  description={`Sign up free in one step. PRO unlocks 30 hosted-AI tools — transcription, OCR, translation, text-to-speech, image generation, long-context PDF Q&A, structured-JSON extraction, content safety, and more. Most cost 1–2 credits. Packs from $${starterPack.usd}, or $${MONTHLY.usdPerMonth}/mo.`}
>
  <article class="pro">
    <!-- Hero: copy left, signup right — mirrors the homepage hero -->
    <section class="pro-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <div class="hero-chip"><ProBadge /><span>Wyreup PRO</span></div>
          <h1 class="hero-title">
            Hosted-AI tools. Pay only for what you run.
          </h1>
          <p class="hero-sub">
            Every tool that runs in your browser stays free. PRO adds the AI
            tools that need real servers — transcription, OCR, translation
            (100+ languages), text-to-speech, image generation, long-context
            PDF Q&A, structured-JSON extraction, content safety, and more.
            Tools chain together so one tool's output feeds the next. Most
            cost 1–2 credits a run; failed runs refund automatically.
          </p>
          <p class="hero-meta">
            Packs from <strong>{`$${starterPack.usd}`}</strong> &nbsp;·&nbsp; or <strong>{`$${MONTHLY.usdPerMonth}/mo`}</strong> &nbsp;·&nbsp; credits never expire
          </p>
          <a href="#pricing" class="hero-jump">See pricing &darr;</a>
        </div>
        <div class="hero-signup">
          <ProSignup client:load />
        </div>
      </div>
    </section>

    <!-- Pricing — second block, nothing to hunt for -->
    <section class="pro-section pro-section--bordered" id="pricing">
      <div class="container">
        <h2 class="section-title">Simple credit pricing</h2>
        <p class="section-sub">
          Buy a pack once — credits never expire — or subscribe monthly.
          Most tools cost 1–2 credits, so a starter pack covers roughly {starterPack.credits}
          images generated or analyzed, {starterPack.credits} grammar fixes, 110 PDF Q&amp;A
          runs, 110 text-to-speech outputs, or 70 transcriptions.
        </p>

        <div class="packs">
          {PACKS.map((p) => (
            <div class={`pack${p.featured ? ' pack--featured' : ''}`}>
              <span class="pack__note">{p.label}</span>
              <div class="pack__credits">{p.credits}</div>
              <div class="pack__label">credits</div>
              <div class="pack__price">{`$${p.usd}`}</div>
            </div>
          ))}
          <div class="pack pack--monthly">
            <span class="pack__note">Monthly</span>
            <div class="pack__credits">{MONTHLY.credits}</div>
            <div class="pack__label">credits / month</div>
            <div class="pack__price">{`$${MONTHLY.usdPerMonth}`}<span class="pack__per">/mo</span></div>
          </div>
        </div>

        <p class="pricing-fine">
          Pack credits never expire. The monthly plan grants {MONTHLY.credits} credits each
          cycle into the same balance — the best per-credit rate — and you
          can cancel anytime. Payment is handled by Lemon Squeezy; we never
          see your card.
        </p>
      </div>
    </section>

    <!-- Catalog -->
    <section class="pro-section pro-section--bordered">
      <div class="container">
        <h2 class="section-title">What PRO unlocks</h2>
        <p class="section-sub">{proTools.length} hosted-AI tools, grouped by what they cost to run. Each shows its credit cost before you run it.</p>
        <div class="cat-grid">
          {catalog.map((g) => (
            <div class="cat-group">
              <h3 class="cat-group__name">{g.cost} {g.cost === 1 ? 'credit' : 'credits'} per run</h3>
              <ul class="cat-list">
                {g.tools.map((t) => (
                  <li class="cat-item">
                    <span class="cat-item__name">{t.name}</span>
                    <span class="cat-item__desc">{t.desc}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="pro-section pro-section--bordered">
      <div class="container">
        <h2 class="section-title">How it works</h2>
        <ol class="steps">
          <li class="step">
            <span class="step__num">01</span>
            <span class="step__verb">Sign up</span>
            <p class="step__body">One field, instant — you're signed in right away. No password.</p>
          </li>
          <li class="step">
            <span class="step__num">02</span>
            <span class="step__verb">Add credits</span>
            <p class="step__body">Pick a pack or the monthly plan. Lemon Squeezy handles payment; we never see your card.</p>
          </li>
          <li class="step">
            <span class="step__num">03</span>
            <span class="step__verb">Run any PRO tool</span>
            <p class="step__body">Each shows its credit cost up front. Credits deduct on success; failed runs refund automatically.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- Why -->
    <section class="pro-section pro-section--bordered">
      <div class="container">
        <h2 class="section-title">Built to be fair</h2>
        <div class="why-grid">
          {why.map((w) => (
            <div class="why-item">
              <h3 class="why-item__h">{w.h}</h3>
              <p class="why-item__p">{w.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Self-host -->
    <section class="pro-section pro-section--bordered">
      <div class="container">
        <div class="self-host">
          <h2 class="self-host__h">Don't want a hosted tier at all?</h2>
          <p class="self-host__p">
            Wyreup is MIT-licensed. Run <code>@wyreup/core</code> entirely on
            your own infrastructure. PRO exists because hosted-AI inference
            has a real per-call cost — not because the free tools are limited.
          </p>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  /* ── Section frame ──
     Sub-page (not the homepage) — normal flow, no viewport rhythm.
     Generous block padding; hairline divider between sections. */
  .pro-section {
    padding-block: clamp(48px, 8vh, 88px);
  }
  .pro-section--bordered {
    border-top: 1px solid var(--border-subtle);
  }

  /* ── Hero — left-aligned, copy + signup, like the homepage hero ── */
  .pro-hero {
    padding-block: clamp(56px, 10vh, 120px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: var(--space-12);
    align-items: start;
  }
  .hero-copy {
    display: flex;
    flex-direction: column;
  }
  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
  }
  .hero-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin: 0 0 var(--space-4);
  }
  .hero-sub {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 34rem;
    margin: 0 0 var(--space-6);
  }
  .hero-meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0 0 var(--space-4);
  }
  .hero-meta strong {
    color: var(--text-primary);
    font-weight: 500;
  }
  .hero-jump {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    width: max-content;
  }
  .hero-jump:hover {
    color: var(--accent-hover);
  }
  .hero-signup {
    position: sticky;
    top: var(--space-8);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .hero-signup {
      position: static;
    }
  }

  /* ── Section headings ── */
  .section-title {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
  }
  .section-sub {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 38rem;
    margin: 0 0 var(--space-8);
  }

  /* ── Pricing ── */
  .packs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 860px) {
    .packs { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 440px) {
    .packs { grid-template-columns: 1fr; }
  }
  .pack {
    position: relative;
    padding: var(--space-6) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .pack--featured {
    border-color: var(--accent);
  }
  .pack--monthly {
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .pack__note {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }
  .pack--featured .pack__note,
  .pack--monthly .pack__note {
    color: var(--accent);
  }
  .pack__credits {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1;
    color: var(--text-primary);
  }
  .pack__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: var(--space-1);
  }
  .pack__price {
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--text-primary);
  }
  .pack__per {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .pricing-fine {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    line-height: 1.6;
    max-width: 38rem;
    margin: var(--space-6) 0 0;
  }

  /* ── Catalog ── */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8) var(--space-12);
  }
  @media (max-width: 720px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
  .cat-group__name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border-subtle);
  }
  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .cat-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-subtle);
  }
  .cat-item:last-child {
    border-bottom: none;
  }
  .cat-item__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }
  .cat-item__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.45;
  }

  /* ── How it works ── */
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  @media (max-width: 720px) {
    .steps { grid-template-columns: 1fr; gap: var(--space-6); }
  }
  .step__num {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .step__verb {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }
  .step__body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Why ── */
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8) var(--space-12);
  }
  @media (max-width: 640px) {
    .why-grid { grid-template-columns: 1fr; gap: var(--space-6); }
  }
  .why-item__h {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
    padding-left: var(--space-3);
    border-left: 2px solid var(--accent);
  }
  .why-item__p {
    margin: 0;
    padding-left: var(--space-3);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Self-host ── */
  .self-host {
    max-width: 38rem;
  }
  .self-host__h {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
  }
  .self-host__p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.6;
  }
  .self-host__p code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 1px 5px;
  }
</style>
