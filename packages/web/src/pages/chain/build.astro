---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChainBuilder from '../../components/ChainBuilder.svelte';
import { createDefaultRegistry } from '@wyreup/core';

const registry = createDefaultRegistry();
const tools = Array.from(registry.toolsById.values()).map((t) => ({
  id: t.id,
  name: t.name,
  description: t.description,
  inputAccept: t.input.accept,
  inputMin: t.input.min,
  outputMime: t.output.mime,
  defaults: t.defaults as Record<string, unknown>,
  paramSchema: t.paramSchema as Record<string, import('@wyreup/core').ParamFieldSchema> | undefined,
  requires: t.requires
    ? { webgpu: t.requires.webgpu, minMemoryGB: t.requires.minMemoryGB }
    : undefined,
}));
---

<BaseLayout
  title="Build a chain — Wyreup"
  description="Compose a pipeline of tools. Pick a tool, pick what happens with its output, repeat. Share the result as a URL."
>
  <section class="chain-build-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Wyreup</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__current" aria-current="page">Build a chain</span>
      </nav>

      <header class="page-header">
        <h1 class="page-title">Build a chain</h1>
        <p class="page-subhead">Pick a tool, pick what happens with its output, repeat. Drop a file at the top to run.</p>
      </header>

      <ChainBuilder client:load {tools} />
    </div>
  </section>
</BaseLayout>

<style>
  .chain-build-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  .container {
    max-width: 860px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .breadcrumb__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .breadcrumb__link:hover { color: var(--text-primary); }

  .breadcrumb__sep { color: var(--text-subtle); }
  .breadcrumb__current { color: var(--text-primary); }

  .page-header {
    margin-bottom: var(--space-8);
  }

  .page-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: var(--space-3);
  }

  .page-subhead {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
  }
</style>
