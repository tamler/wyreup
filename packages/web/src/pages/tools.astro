---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolFilter from '../components/ToolFilter.svelte';
import PwaOnboardBanner from '../components/PwaOnboardBanner.svelte';
import SavedChainsSection from '../components/SavedChainsSection.svelte';
import { createDefaultRegistry } from '@wyreup/core';

const registry = createDefaultRegistry();

// Extract serializable tool data (no functions / components)
const tools = Array.from(registry.toolsById.values()).map((t) => ({
  id: t.id,
  name: t.name,
  category: t.category,
  categories: t.categories ?? [],
  description: t.description,
  keywords: t.keywords ?? [],
  requiresWebgpu: t.requires?.webgpu,
  requires: t.requires
    ? { webgpu: t.requires.webgpu, minMemoryGB: t.requires.minMemoryGB }
    : undefined,
  installSize: t.installSize,
  installGroup: (t as { installGroup?: string }).installGroup,
  accept: t.input.accept,
}));

// Sorted unique categories — include both the primary `category` and
// any additional `categories[]` membership so the chip row covers
// every bucket a tool can surface under.
const categories = [
  ...new Set(
    tools.flatMap((t) => [t.category, ...(t.categories ?? [])]),
  ),
].sort();

interface ExampleChain {
  id: string;
  name: string;
  description: string;
  situation: string;
  steps: string[];
  inputHint: string;
  outputHint: string;
}

const exampleChains: ExampleChain[] = [
  {
    id: 'privacy',
    name: 'Share a photo safely',
    description: 'Strip metadata, blur faces, compress for sharing.',
    situation: 'Before emailing a photo — strip the GPS data, blur faces, shrink it.',
    steps: ['strip-exif', 'face-blur', 'compress'],
    inputHint: 'Drop a JPG/PNG photo',
    outputHint: 'Anonymized, smaller image',
  },
  {
    id: 'receipts',
    name: 'Receipts to one PDF',
    description: 'Convert images to PDF, then merge them into a single document.',
    situation: 'When you have a pile of receipt photos and need one PDF for expenses.',
    steps: ['image-to-pdf', 'merge-pdf'],
    inputHint: 'Drop 2+ receipt images',
    outputHint: 'One searchable PDF',
  },
  {
    id: 'scan-to-text',
    name: 'Scan to searchable text',
    description: 'OCR a scanned document, then word-count the result.',
    situation: 'When you have a scanned page and need the words out of it.',
    steps: ['ocr', 'word-counter'],
    inputHint: 'Drop a scanned PDF or image',
    outputHint: 'Plain text + word stats',
  },
  {
    id: 'web-ready',
    name: 'Optimize for web',
    description: 'Resize to web dimensions, compress for bandwidth, strip metadata.',
    situation: 'Before uploading a photo to a site — resize it, compress it, clean it.',
    steps: ['resize', 'compress', 'strip-exif'],
    inputHint: 'Drop a high-res JPG/PNG',
    outputHint: 'Web-ready image',
  },
  {
    id: 'redact-share',
    name: 'Redact and lock a PDF',
    description: 'Redact sensitive regions, encrypt with password, add page numbers.',
    situation: 'Before sharing a contract — black out the sensitive bits, then lock it.',
    steps: ['pdf-redact', 'pdf-encrypt', 'page-numbers-pdf'],
    inputHint: 'Drop a contract or document PDF',
    outputHint: 'Locked, numbered, redacted PDF',
  },
  {
    id: 'dev-data',
    name: 'Clean up JSON for docs',
    description: 'Format JSON, convert to YAML, then copy as pretty text.',
    situation: 'When a config file is minified and you need it readable.',
    steps: ['json-formatter', 'json-yaml'],
    inputHint: 'Drop a .json file',
    outputHint: 'Formatted YAML',
  },
  {
    id: 'voice-memo',
    name: 'Voice memo to summary',
    description: 'Transcribe a recording, then summarize the transcript.',
    situation: "After a meeting or interview when you want the gist, not the full text.",
    steps: ['transcribe', 'text-summarize'],
    inputHint: 'Drop an audio file (wav, mp3, m4a)',
    outputHint: 'Short text summary',
  },
  {
    id: 'meeting-translate',
    name: 'Foreign-language audio to English summary',
    description: 'Transcribe non-English speech, translate, then summarize.',
    situation: 'When a colleague sends a voice memo in a language you do not speak.',
    steps: ['transcribe', 'text-translate', 'text-summarize'],
    inputHint: 'Drop a recording in any language',
    outputHint: 'English summary',
  },
  {
    id: 'alt-text',
    name: 'Image to alt-text',
    description: 'Caption an image, then translate to your target locale.',
    situation: 'Building accessible content in multiple languages.',
    steps: ['image-caption', 'text-translate'],
    inputHint: 'Drop a JPG/PNG/WebP',
    outputHint: 'Translated alt-text',
  },
  {
    id: 'csv-to-google-earth',
    name: 'Spreadsheet of locations to Google Earth',
    description: 'Turn a CSV of lat/lng rows into a KML file you can open in Google Earth.',
    situation: 'When someone hands you a list of addresses or coordinates and wants them on a map.',
    steps: ['csv-to-geojson', 'geojson-to-kml'],
    inputHint: 'Drop a .csv with latitude/longitude columns',
    outputHint: 'KML for Google Earth or My Maps',
  },
];

// Helper: get a display name for a tool ID (fallback to the ID itself)
function toolDisplayName(id: string): string {
  const tool = tools.find((t) => t.id === id);
  return tool ? tool.name : id;
}
---

<BaseLayout
  title="Tools — Wyreup"
  description="Browser-native tools across image, PDF, audio, text, and dev categories. Compress, convert, inspect, redact — nothing uploads."
  ogDescription="Browser-native tools. Image editing, PDF processing, text utilities, dev tools — all run locally, no uploads."
>
  <div class="reserve-pwa-banner">
    <PwaOnboardBanner client:load />
  </div>
  <section class="tools-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">Tools</h1>
      </div>

      <div class="reserve-saved-chains">
        <SavedChainsSection client:load />
      </div>

      <ToolFilter
        client:load
        tools={tools}
        categories={categories}
      />

      <!-- Example Chains section -->
      <div class="chains-section">
        <div class="chains-header">
          <h2 class="chains-title">Example chains</h2>
          <p class="chains-subhead">One drop. Multi-step outcome. Each step's output becomes the next step's input.</p>
        </div>

        <div class="chains-grid">
          {exampleChains.map((chain, ci) => (
            <div
              class="chain-card brackets"
              style={`--stagger-delay: ${ci * 80}ms`}
            >
              <div class="brackets-inner" aria-hidden="true"></div>
              <div class="chain-card__inner">
                <div class="chain-card__name">{chain.name}</div>
                <p class="chain-card__situation">"{chain.situation}"</p>
                <p class="chain-card__desc">{chain.description}</p>

                <div class="chain-flow" aria-label={`Chain steps: ${chain.steps.join(', ')}`}>
                  {chain.steps.map((stepId, si) => (
                    <>
                      <span class="chain-step">{toolDisplayName(stepId)}</span>
                      {si < chain.steps.length - 1 && (
                        <span class="chain-connector" aria-hidden="true">
                          <span class="chain-connector__line"></span>
                          <span class="chain-connector__pad"></span>
                          <span class="chain-connector__arrow">&#8594;</span>
                        </span>
                      )}
                    </>
                  ))}
                </div>

                <div class="chain-hints">
                  <span class="chain-hint chain-hint--in">{chain.inputHint}</span>
                  <span class="chain-hint__sep" aria-hidden="true">&#8594;</span>
                  <span class="chain-hint chain-hint--out">{chain.outputHint}</span>
                </div>

                <div class="chain-action">
                  <a
                    href={`/tools/${chain.steps[0]}`}
                    class="chain-start-link"
                    aria-label={`Start chain: ${chain.name}`}
                  >Start &#8594;</a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tools-page {
    padding: var(--space-8) 0;
  }

  .page-header {
    margin-bottom: var(--space-6);
  }

  .page-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .page-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  /* Example chains section */
  .chains-section {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  .chains-header {
    margin-bottom: var(--space-6);
  }

  .chains-title {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-2);
  }

  .chains-subhead {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-sans);
    line-height: 1.5;
    margin: 0;
  }

  .chains-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 768px) {
    .chains-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Chain card — double-bezel matching tool-card */
  .chain-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1px;
    position: relative;
    overflow: visible;
    opacity: 0;
    transform: translateY(8px);
    animation: card-reveal 200ms cubic-bezier(0, 0, 0.2, 1) forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  @keyframes card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chain-card:hover {
    border-color: var(--text-muted);
  }

  .chain-card__inner {
    background: var(--bg-raised);
    border: 1px solid var(--border-subtle);
    border-radius: calc(var(--radius-md) - 1px);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .chain-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--accent-text);
    line-height: 1.25;
  }

  .chain-card__situation {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-primary);
    line-height: 1.4;
    margin: 0;
    font-style: italic;
  }

  .chain-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
  }

  /* Chain flow visualization */
  .chain-flow {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
  }

  .chain-step {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-primary);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 2px var(--space-2);
    white-space: nowrap;
  }

  .chain-connector {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    color: var(--text-subtle);
    flex-shrink: 0;
  }

  .chain-connector__line {
    display: block;
    width: 8px;
    height: 1px;
    background: var(--border);
  }

  .chain-connector__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  .chain-connector__arrow {
    font-size: var(--text-xs);
    color: var(--text-subtle);
    line-height: 1;
  }

  /* Hints row */
  .chain-hints {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .chain-hint {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .chain-hint--in {
    color: var(--text-subtle);
  }

  .chain-hint--out {
    color: var(--text-muted);
  }

  .chain-hint__sep {
    color: var(--text-subtle);
    font-size: var(--text-xs);
  }

  /* Action row */
  .chain-action {
    margin-top: var(--space-1);
  }

  .chain-start-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent-text);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .chain-start-link:hover {
    color: var(--accent-hover);
  }

  .chain-start-link:focus-visible {
    outline: 2px solid var(--accent-hover);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
</style>
