---
import { createDefaultRegistry } from '@wyreup/core';
import JobLauncher from '../components/JobLauncher.svelte';
import { encodeChainSteps } from '../components/runners/chainUrl';
import { JOBS, type Job } from '../data/jobs';
import { displayName } from '../data/display-names';
import { upsellFor } from '../data/pro-upsells';
import { approxUsd } from '../data/pricing';
import BaseLayout from '../layouts/BaseLayout.astro';
import { JOB_SEO_CONTENT, type JobSeoContent } from '../lib/job-seo-content';

export function getStaticPaths() {
  const reservedRoutes = new Set([
    'tools',
    'about',
    'pro',
    'cli',
    'mcp',
    'skill',
    'settings',
    'toolbelt',
    'triggers',
    'chain',
    'category',
    'legal',
    'account',
    'admin',
    'share',
    'share-receive',
    '404',
  ]);
  const collisions = JOBS.filter((job) => reservedRoutes.has(job.slug));
  if (collisions.length > 0) {
    throw new Error(
      `Job slugs collide with reserved routes: ${collisions.map((job) => job.slug).join(', ')}`,
    );
  }

  const registry = createDefaultRegistry();

  return JOBS.map((job) => {
    const seoContent = JOB_SEO_CONTENT[job.slug];
    if (!seoContent) {
      throw new Error(`Missing SEO content for job "${job.slug}".`);
    }
    const toolIds =
      job.action.kind === 'tool'
        ? [job.action.toolId]
        : job.action.steps.map((step) => step.toolId);
    const tools = toolIds.map((toolId) => {
      const tool = registry.toolsById.get(toolId);
      if (!tool) {
        throw new Error(`Job "${job.slug}" references unknown tool "${toolId}".`);
      }
      return tool;
    });
    const hasHostedStep = tools.some((tool) => tool.cost === 'credit');
    // Quality-first Pro seam: if the job's primary tool has a hosted
    // sibling, offer the stronger version — benefit first, price as detail.
    const upsell = upsellFor(toolIds[0]!);
    const upsellTool = upsell ? registry.toolsById.get(upsell.proToolId) : undefined;
    const proSeam =
      upsell && upsellTool
        ? {
            proToolId: upsell.proToolId,
            benefit: upsell.benefit,
            creditCost: upsellTool.creditCost ?? 1,
          }
        : null;
    // The launcher must accept only what the RECEIVING tool accepts — the
    // job's acceptMimes wildcards (image/*) can be broader than the first
    // tool's concrete list (compress rejects HEIC/SVG/GIF).
    const serializedJob = {
      slug: job.slug,
      title: job.title,
      action: job.action,
      acceptMimes: [...tools[0]!.input.accept],
    };

    return {
      params: { job: job.slug },
      props: {
        job,
        seoContent,
        serializedJob,
        toolNames: tools.map((tool) => displayName(tool.id, tool.name)),
        executionSentence: hasHostedStep
          ? 'Uses a hosted PRO step — you approve before anything is sent.'
          : 'Runs entirely on your device — the file never uploads.',
        chainBuilderHref:
          job.action.kind === 'chain'
            ? `/chain/build?steps=${encodeURIComponent(encodeChainSteps(job.action.steps))}`
            : null,
        proSeam,
      },
    };
  });
}

interface PageProps {
  job: Job;
  seoContent: JobSeoContent;
  serializedJob: Pick<Job, 'slug' | 'title' | 'action' | 'acceptMimes'>;
  toolNames: string[];
  executionSentence: string;
  chainBuilderHref: string | null;
  proSeam: { proToolId: string; benefit: string; creditCost: number } | null;
}

const { job, seoContent, serializedJob, toolNames, executionSentence, chainBuilderHref, proSeam } =
  Astro.props as PageProps;

const pageUrl = `https://wyreup.com/${job.slug}`;
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Wyreup', item: 'https://wyreup.com/' },
    { '@type': 'ListItem', position: 2, name: job.title, item: pageUrl },
  ],
};
const webPageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: job.title,
  description: job.description,
  url: pageUrl,
};
const faqLd =
  seoContent.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: seoContent.faq.map((entry) => ({
          '@type': 'Question',
          name: entry.q,
          acceptedAnswer: { '@type': 'Answer', text: entry.a },
        })),
      }
    : null;
---

<BaseLayout
  title={`${job.title} — Wyreup`}
  description={job.description}
  surfaceMode="welcome"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageLd)} />
    {faqLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    )}
    <script is:inline>
      // Aggregate, cookieless seam-click counter — no identifiers.
      document.addEventListener('click', (e) => {
        const a = e.target instanceof Element ? e.target.closest('[data-seam]') : null;
        if (!a) return;
        try {
          navigator.sendBeacon(
            '/api/metrics/hit',
            JSON.stringify({ kind: 'job-seam-click', detail: a.getAttribute('data-seam') }),
          );
        } catch {
          /* best-effort */
        }
      });
    </script>
  </Fragment>

  <section class="job-page">
    <div class="container job-page__container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Wyreup</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__current" aria-current="page">{job.title}</span>
      </nav>

      <header class="job-header">
        <h1 class="job-title">{job.title}</h1>
        <p class="job-lede">
          {job.description} <span class="job-lede__execution">{executionSentence}</span>
        </p>
      </header>

      <JobLauncher client:load job={serializedJob} />

      <section class="outcome" aria-labelledby="what-happens-heading">
        <h2 id="what-happens-heading" class="outcome__title">What happens</h2>
        <ol class="outcome__steps">
          {toolNames.map((toolName) => <li>{toolName}</li>)}
        </ol>
      </section>

      <section class="job-content" aria-labelledby="about-heading">
        <h2 id="about-heading" class="job-content__title">About</h2>
        <p class="job-content__intro">{seoContent.intro}</p>
      </section>

      <section class="job-content" aria-labelledby="common-uses-heading">
        <h2 id="common-uses-heading" class="job-content__title">Common uses</h2>
        <ul class="job-content__uses">
          {seoContent.useCases.map((useCase) => <li>{useCase}</li>)}
        </ul>
      </section>

      <section class="job-content" aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="job-content__title">Frequently asked questions</h2>
        <div class="job-faq-list">
          {seoContent.faq.map((entry) => (
            <details class="job-faq-item">
              <summary class="job-faq-question">{entry.q}</summary>
              <div class="job-faq-answer"><p>{entry.a}</p></div>
            </details>
          ))}
        </div>
      </section>

      {proSeam && (
        <aside class="job-pro-seam">
          <p class="job-pro-seam__benefit">
            <span class="job-pro-seam__chip">PRO</span>
            {proSeam.benefit}
          </p>
          <a class="job-pro-seam__link" href={`/tools/${proSeam.proToolId}`} data-seam={proSeam.proToolId}>
            Try the stronger version &rarr;
          </a>
          <p class="job-pro-seam__cost">
            {proSeam.creditCost} {proSeam.creditCost === 1 ? 'credit' : 'credits'} per run · {approxUsd(proSeam.creditCost)}
          </p>
        </aside>
      )}

      <nav class="job-links" aria-label="More ways to use Wyreup">
        <a href="/tools">Browse all tools &rarr;</a>
        {chainBuilderHref && <a href={chainBuilderHref}>Open in chain builder &rarr;</a>}
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .job-page {
    padding: clamp(48px, 7vh, 88px) 0 var(--space-16);
  }

  .job-page__container {
    max-width: 920px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .breadcrumb__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .breadcrumb__link:hover {
    color: var(--text-primary);
  }

  .breadcrumb__sep {
    color: var(--text-subtle);
  }

  .breadcrumb__current {
    color: var(--text-primary);
  }

  .job-header {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }

  .job-title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-sans);
    font-size: clamp(2.25rem, 7vw, var(--text-hero));
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .job-lede {
    max-width: 680px;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--text-muted);
  }

  .job-lede__execution {
    color: var(--text-primary);
  }

  .outcome {
    display: grid;
    grid-template-columns: minmax(140px, 0.35fr) minmax(0, 1fr);
    gap: var(--space-8);
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .outcome__title {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .outcome__steps {
    display: grid;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: outcome-step;
  }

  .outcome__steps li {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    gap: var(--space-3);
    align-items: baseline;
    font-size: var(--text-md);
    color: var(--text-primary);
    counter-increment: outcome-step;
  }

  .outcome__steps li::before {
    content: counter(outcome-step, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent-text);
  }

  .job-content {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border-subtle);
  }

  .job-content__title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .job-content__intro {
    max-width: 70ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--text-muted);
  }

  .job-content__uses {
    max-width: 70ch;
    margin: 0;
    padding-left: var(--space-5);
    list-style: disc;
  }

  .job-content__uses li {
    margin-bottom: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text-muted);
  }

  .job-content__uses li:last-child {
    margin-bottom: 0;
  }

  .job-faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 70ch;
  }

  .job-faq-item {
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
  }

  .job-faq-item[open] {
    border-color: var(--border);
  }

  .job-faq-question {
    position: relative;
    padding-right: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
  }

  .job-faq-question::-webkit-details-marker {
    display: none;
  }

  .job-faq-question::after {
    position: absolute;
    top: 0;
    right: 0;
    font-size: var(--text-lg);
    font-weight: 400;
    line-height: 1;
    color: var(--text-subtle);
    content: '+';
  }

  .job-faq-item[open] .job-faq-question::after {
    content: '−';
  }

  .job-faq-answer {
    padding-top: var(--space-2);
    margin-top: var(--space-2);
    border-top: 1px solid var(--border-subtle);
  }

  .job-faq-answer p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--text-muted);
  }

  .job-pro-seam {
    margin-top: var(--space-8);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--radius-md);
    background: var(--bg-elevated);
    max-width: 560px;
  }
  .job-pro-seam__chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--accent);
    color: var(--text-on-accent, #000);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    margin-right: var(--space-2);
    letter-spacing: 0.04em;
  }
  .job-pro-seam__benefit {
    margin: 0 0 var(--space-2);
    color: var(--text-primary);
  }
  .job-pro-seam__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent-text);
  }
  .job-pro-seam__cost {
    margin: var(--space-2) 0 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .job-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    padding-top: var(--space-8);
  }

  .job-links a {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--accent-text);
    text-decoration: none;
  }

  .job-links a:hover {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .job-page {
      padding-top: var(--space-8);
    }

    .breadcrumb {
      margin-bottom: var(--space-6);
    }

    .outcome {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
