---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Wyreup"
  description="Wyreup is a free, open-source library of browser-native tools. Every tool runs on your device — your files never upload, never cache, never phone home."
>
  <section class="about-page">
    <div class="container">

      <div class="about-hero">
        <h1 class="about-title">Wyreup is for everyone with files.</h1>
      </div>

      <div class="about-body">

        <div class="about-section">
          <div class="about-prose">
            <p class="about-lede">Photos that need resizing. PDFs that need merging. Audio that needs trimming. Video that needs converting. The kind of small file tasks that come up in everyday life — and the kind that most tools want you to upload your private data to solve.</p>
            <p class="about-lede">Wyreup runs every tool on your device. Your files never leave your computer. There's no account, no upload, no tracking — just tools that do their job and get out of the way.</p>
            <p>MIT-licensed. Open source. Verifiable. If you don't trust us, read the code.</p>
          </div>
        </div>

        <div class="section-rule" aria-hidden="true">
          <span class="section-rule__line"></span>
          <span class="section-rule__pad"></span>
        </div>

        <div class="about-section">
          <h2 class="about-section-title">However you work</h2>
          <ul class="surfaces-list">
            <li><strong>If you're at your desk</strong>, drop a file in your <a href="/">browser</a>.</li>
            <li><strong>If you live in the terminal</strong>, install the <a href="/cli">CLI</a>.</li>
            <li><strong>If you work alongside an AI assistant</strong>, install the <a href="/skill">agent skill</a>.</li>
          </ul>
        </div>

        <div class="section-rule" aria-hidden="true">
          <span class="section-rule__line"></span>
          <span class="section-rule__pad"></span>
        </div>

        <div class="about-section">
          <h2 class="about-section-title">Principles</h2>
          <ul class="principles-list">
            <li class="principle">
              <div class="principle__rule" aria-hidden="true">
                <span class="principle__line"></span>
                <span class="principle__pad"></span>
              </div>
              <div class="principle__text">
                <strong>Nothing uploads. Everything runs on your device.</strong>
                <span>No server ever receives your file. Processing happens inside the browser, using your CPU and GPU.</span>
              </div>
            </li>
            <li class="principle">
              <div class="principle__rule" aria-hidden="true">
                <span class="principle__line"></span>
                <span class="principle__pad"></span>
              </div>
              <div class="principle__text">
                <strong>No analytics. No cookies. No third-party scripts.</strong>
                <span>The page loads one origin's code. Nothing phones home. No consent banners needed because there's nothing to consent to.</span>
              </div>
            </li>
            <li class="principle">
              <div class="principle__rule" aria-hidden="true">
                <span class="principle__line"></span>
                <span class="principle__pad"></span>
              </div>
              <div class="principle__text">
                <strong>MIT-licensed. You can audit and self-host.</strong>
                <span>Every line is public. Fork it, inspect it, run it on your own infrastructure.</span>
              </div>
            </li>
            <li class="principle">
              <div class="principle__rule" aria-hidden="true">
                <span class="principle__line"></span>
                <span class="principle__pad"></span>
              </div>
              <div class="principle__text">
                <strong>Built to be boring.</strong>
                <span>Not chasing AI trends. Shipping tools that work, that stay working, and that do exactly what they say.</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="section-rule" aria-hidden="true">
          <span class="section-rule__line"></span>
          <span class="section-rule__pad"></span>
        </div>

        <div class="about-section">
          <h2 class="about-section-title">Who built this</h2>
          <p class="about-prose-single">Built by people who care about privacy more than metrics.</p>
        </div>

        <div class="section-rule" aria-hidden="true">
          <span class="section-rule__line"></span>
          <span class="section-rule__pad"></span>
        </div>

        <div class="about-section">
          <h2 class="about-section-title">Contact</h2>
          <ul class="contact-list">
            <li class="contact-item">
              <div class="contact-item__rule" aria-hidden="true">
                <span class="contact-item__line"></span>
                <span class="contact-item__pad"></span>
              </div>
              <div class="contact-item__text">
                <span class="contact-item__label">General</span>
                <a href="mailto:hello@wyreup.com" class="contact-item__value">hello@wyreup.com</a>
              </div>
            </li>
            <li class="contact-item">
              <div class="contact-item__rule" aria-hidden="true">
                <span class="contact-item__line"></span>
                <span class="contact-item__pad"></span>
              </div>
              <div class="contact-item__text">
                <span class="contact-item__label">Security</span>
                <a href="mailto:security@wyreup.com" class="contact-item__value">security@wyreup.com</a>
              </div>
            </li>
            <li class="contact-item">
              <div class="contact-item__rule" aria-hidden="true">
                <span class="contact-item__line"></span>
                <span class="contact-item__pad"></span>
              </div>
              <div class="contact-item__text">
                <span class="contact-item__label">Source</span>
                <a href="https://github.com/tamler/wyreup" class="contact-item__value" target="_blank" rel="noopener noreferrer">github.com/tamler/wyreup</a>
              </div>
            </li>
          </ul>
        </div>

        <div class="section-rule" aria-hidden="true">
          <span class="section-rule__line"></span>
          <span class="section-rule__pad"></span>
        </div>

        <div class="about-section about-links">
          <a
            href="https://github.com/tamler/wyreup"
            class="about-github-link"
            target="_blank"
            rel="noopener noreferrer"
          >View source on GitHub &rarr;</a>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    padding: var(--space-12) 0 var(--space-16);
  }

  .about-hero {
    margin-bottom: var(--space-12);
  }

  .about-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    font-family: var(--font-sans);
    max-width: 640px;
  }

  .about-body {
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .about-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-section-title {
    font-size: var(--text-base);
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
  }

  .about-prose {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about-prose p,
  .about-prose-single {
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
  }

  .about-lede {
    font-size: var(--text-lg) !important;
    line-height: 1.6 !important;
  }

  .surfaces-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .surfaces-list li {
    font-size: var(--text-base);
    font-family: var(--font-sans);
    color: var(--text-muted);
    line-height: 1.6;
  }

  .surfaces-list li strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .surfaces-list li a {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .surfaces-list li a:hover {
    color: var(--text-primary);
  }

  /* Solder-pad section rule */
  .section-rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .section-rule__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .section-rule__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* Principles list */
  .principles-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .principle {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .principle__rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .principle__line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--border-subtle);
    flex-shrink: 0;
  }

  .principle__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .principle__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .principle__text strong {
    font-size: var(--text-base);
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text-primary);
  }

  .principle__text span {
    font-size: var(--text-sm);
    font-family: var(--font-sans);
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Contact list */
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-item__rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .contact-item__line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--border-subtle);
    flex-shrink: 0;
  }

  .contact-item__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  .contact-item__text {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
  }

  .contact-item__label {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    width: 64px;
    flex-shrink: 0;
  }

  .contact-item__value {
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .contact-item__value:hover {
    color: var(--text-primary);
  }

  /* GitHub link */
  .about-github-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .about-github-link:hover {
    color: var(--text-muted);
  }
</style>
