---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { createDefaultRegistry } from '@wyreup/core';

export async function getStaticPaths() {
  const registry = createDefaultRegistry();
  const allTools = Array.from(registry.toolsById.values());
  const categories = [...new Set(allTools.map((t) => t.category))].sort();

  // Hand-written SEO intro copy per category (Signal voice: terse, no exclamation marks)
  const categoryMeta: Record<string, { displayName: string; h1: string; sub: string; description: string; intro: string }> = {
    image: {
      displayName: 'Image',
      h1: 'Work with images.',
      sub: 'Compress, convert, resize, blur faces, strip metadata. Nothing uploads.',
      description: 'Compress, convert, resize, and edit images in your browser. Strip EXIF metadata, blur faces, remove backgrounds. No upload required.',
      intro: `Compress a photo for email. Convert HEIC to JPG. Strip camera metadata and GPS coordinates before sharing. Blur faces in a crowd shot. Resize for the web. Remove a background without a subscription. All image operations run on your device — the file you drop never leaves the browser tab.

Every tool in this category handles common image tasks that used to require desktop software or paid cloud services. Drop a file, pick settings, download the result.`,
    },
    pdf: {
      displayName: 'PDF',
      h1: 'Do things with PDFs.',
      sub: 'Merge, split, compress, redact, extract. Every operation runs on your device.',
      description: 'Merge, split, rotate, encrypt, and redact PDF files. All processing runs in your browser — nothing uploads to a server.',
      intro: `Split a long scan into single pages. Merge contracts into one file. Redact sensitive sections before sending. Encrypt with a password. Add page numbers to a submission. Rotate a mis-scanned page. Every Wyreup PDF tool runs in your browser — the file you drop never uploads to a server.

PDF manipulation usually requires a desktop app or a cloud service that stores your documents. Wyreup keeps that processing local.`,
    },
    media: {
      displayName: 'Media',
      h1: 'Convert audio and video.',
      sub: 'Trim, convert formats, extract audio, compress. All in your browser.',
      description: 'Convert, compress, trim, and edit video and audio files in your browser. No upload, no server processing.',
      intro: `Convert a video to a different format. Trim a clip to the right length. Extract audio from a recording. Compress a large video for sharing. Add subtitles directly to the video file. Speed up or slow down footage. All media processing uses browser-native codec APIs — no file leaves your device.

Video and audio work have historically required heavy desktop software. These tools handle the common cases without installation.`,
    },
    audio: {
      displayName: 'Audio',
      h1: 'Make audio sound better.',
      sub: 'Upscale low-quality recordings. Convert between formats.',
      description: 'Enhance and process audio files in your browser. Noise reduction and quality improvement, fully on-device.',
      intro: `Enhance a voice recording with noise reduction. Clean up audio before transcription or sharing. Audio processing runs entirely in your browser using local compute — your recording never touches an external server.

Clear audio matters for transcription accuracy, accessibility, and professional output. These tools handle the preprocessing step that makes everything downstream easier.`,
    },
    convert: {
      displayName: 'Convert',
      h1: 'Turn one format into another.',
      sub: 'Images, PDFs, documents, data.',
      description: 'Convert files between formats — images, documents, spreadsheets, markup, and data. All conversions run locally.',
      intro: `Convert Markdown to HTML for a CMS. Transform CSV to JSON for an API. Turn an SVG into a PNG at any size. Convert spreadsheet formats without Excel. Encode and decode Base64. Convert HTML back to readable Markdown. Each conversion happens in your browser with no intermediate server.

Format conversion is one of the most frequent developer and document tasks. These tools cover the common cases quickly.`,
    },
    edit: {
      displayName: 'Edit',
      h1: 'Tweak a file.',
      sub: 'Crop, rotate, flip, watermark. No signup.',
      description: 'Crop, rotate, flip, watermark, and adjust images and PDFs directly in your browser.',
      intro: `Crop an image to a specific region. Rotate a mis-oriented photo. Apply a grayscale or sepia filter. Add a watermark to protect your work. Extract or delete specific pages from a PDF. Crop a PDF to a region. These are the edit operations you reach for before sending a file on.

All editing runs locally — no account needed, no file stored on a third-party server.`,
    },
    optimize: {
      displayName: 'Optimize',
      h1: 'Shrink files.',
      sub: 'Reduce file sizes without losing quality you will notice.',
      description: 'Compress images, PDFs, and SVGs to reduce file size without losing quality. Runs entirely on your device.',
      intro: `Compress a JPEG before attaching it to an email. Shrink a PDF for a file upload limit. Optimize an SVG for a webpage. Upscale a small image to double its resolution using AI. File size reduction matters for email, storage, and web performance.

These tools apply the right optimization algorithm for each file type — lossy compression for photos, lossless for documents and vectors.`,
    },
    privacy: {
      displayName: 'Privacy',
      h1: 'Leave nothing behind.',
      sub: 'Strip metadata, encrypt PDFs, blur faces, redact regions.',
      description: 'Strip metadata, blur faces, remove backgrounds, and encrypt files. Every privacy tool runs on your device.',
      intro: `Strip GPS and camera data from a photo before posting. Blur faces in a group shot. Remove a background without a cloud service that stores your images. Encrypt a file with PGP before sending. Verify a PGP signature on a received document. Privacy tools are only meaningful if they are trustworthy — these run entirely on your device with no network calls.

The file you process never leaves your browser. You can verify that claim in the source code.`,
    },
    create: {
      displayName: 'Create',
      h1: 'Make small things.',
      sub: 'QR codes, UUIDs, passwords, lorem ipsum.',
      description: 'Generate QR codes, passwords, UUIDs, favicons, barcodes, and other outputs without a backend.',
      intro: `Generate a QR code for a URL or contact card. Create a secure random password. Produce a UUID for a database record. Build a favicon set from an image. Generate a barcode for a product label. Produce lorem ipsum placeholder text. Create a slug for a URL.

Generation tools produce something from nothing or from minimal input. All computation runs in your browser — no API key, no signup, no rate limit.`,
    },
    inspect: {
      displayName: 'Inspect',
      h1: 'See inside a file.',
      sub: 'Dimensions, metadata, hashes, structure.',
      description: 'Examine file metadata, diff images and text, decode tokens, and analyze color — all in your browser.',
      intro: `Read the EXIF metadata embedded in a photo. Check the dimensions, colorspace, and bit depth of an image. Diff two images to find pixel-level differences. Parse a JWT without a decoder service. Test a regex against sample input. Count words in a document. Inspect a ZIP before extracting it. Read color values in any format.

Inspection tools tell you what is in a file or string without modifying it. Useful for debugging, verification, and auditing.`,
    },
    export: {
      displayName: 'Export',
      h1: 'Pull content out.',
      sub: 'Extract text, tables, pages, or convert to simpler formats.',
      description: 'Extract text, run OCR, and export structured data from documents. All extraction runs in your browser.',
      intro: `Extract plain text from a PDF for further processing. Run OCR on a scanned image or document to get searchable text. Extract tables from a PDF into structured JSON. Pull audio from a video file. Export data to a format your next tool expects.

Extraction is the first step in many document workflows. Getting clean output out of a file lets you process it further without manual copying.`,
    },
    text: {
      displayName: 'Text',
      h1: 'Clean up text and data.',
      sub: 'Format JSON, decode JWTs, diff text, count words.',
      description: 'Analyze, translate, summarize, and transform text using on-device AI models. No data leaves your browser.',
      intro: `Analyze the sentiment of a review or feedback batch. Run named entity recognition to extract names, places, and organizations. Summarize a long document. Translate text between languages. Compute readability scores for content targeting. Get word and character statistics. Calculate token counts for LLM input planning.

Text AI tools use browser-native model inference where possible. Input text stays in your browser tab.`,
    },
    dev: {
      displayName: 'Dev',
      h1: 'Clean up text and data.',
      sub: 'Format JSON, decode JWTs, diff text, count words.',
      description: 'Format JSON, YAML, SQL, CSS, and HTML. Convert data formats. Decode tokens and parse cron expressions.',
      intro: `Format a minified JSON payload for reading. Convert CSV to JSON for an API call. Decode a JWT to inspect its claims. Parse a cron expression to verify its schedule. Format SQL before committing it. Convert between number bases. Escape and unescape strings. Count tokens in a prompt before sending it to an LLM.

Developer utility tools handle the small-but-frequent text transformation tasks that slow down workflows when you have to search for a tool each time.`,
    },
    finance: {
      displayName: 'Finance',
      h1: 'Quick math.',
      sub: 'Compound interest, dollar-cost averaging, percentages, dates.',
      description: 'Calculate compound interest, model DCA investment strategies, and run financial projections in your browser.',
      intro: `Calculate how a lump sum grows under compound interest over time. Model a dollar-cost averaging investment plan across different contribution schedules. Run financial projections with different rate assumptions. All computation runs locally — no financial data leaves your device.

Financial calculators are a common daily-use tool for investors and planners. These cover the core quantitative cases without requiring a spreadsheet or a financial platform account.`,
    },
    archive: {
      displayName: 'Archive',
      h1: 'Zip and unzip.',
      sub: 'Create, extract, inspect archives.',
      description: 'Create ZIP archives, extract ZIP files, and inspect archive contents — all in your browser.',
      intro: `Create a ZIP archive from multiple files for a single download or email attachment. Extract the contents of a ZIP without installing software. Inspect a ZIP to see its file list and metadata before extracting. Archive tools are the last step before sharing a batch of files and the first step when receiving one.

All archive operations run in-browser using compression APIs. No files are sent to an external server.`,
    },
  };

  return categories.map((cat) => {
    const catTools = allTools.filter((t) => t.category === cat);
    const meta = categoryMeta[cat] ?? {
      displayName: cat.charAt(0).toUpperCase() + cat.slice(1),
      h1: `${cat.charAt(0).toUpperCase() + cat.slice(1)} tools.`,
      sub: `${cat.charAt(0).toUpperCase() + cat.slice(1)} tools that run on your device.`,
      description: `${cat} tools that run in your browser. No upload required.`,
      intro: `These tools handle common ${cat} tasks directly in your browser.`,
    };

    // Related categories: pick up to 4 others that share tools with similar output mimes
    const catMimes = new Set(catTools.map((t) => t.output?.mime));
    const relatedCats = categories
      .filter((c) => c !== cat)
      .filter((c) => {
        const cTools = allTools.filter((t) => t.category === c);
        return cTools.some((t) => catMimes.has(t.output?.mime));
      })
      .slice(0, 4);

    return {
      params: { slug: cat },
      props: {
        cat,
        displayName: meta.displayName,
        catH1: meta.h1,
        catSub: meta.sub,
        metaDescription: meta.description,
        intro: meta.intro,
        catTools: catTools.map((t) => ({
          id: t.id,
          name: t.name,
          category: t.category,
          description: t.description,
        })),
        relatedCats,
        allCategories: categories,
      },
    };
  });
}

const { displayName, catH1, catSub, metaDescription, intro, catTools, relatedCats } = Astro.props;
const introParas = intro.split('\n\n').filter(Boolean);
---

<BaseLayout
  title={`${catH1} — Wyreup`}
  description={metaDescription}
  ogDescription={metaDescription}
  surfaceMode="welcome"
>
  <section class="category-page">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Wyreup</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/tools" class="breadcrumb__link">Tools</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__current" aria-current="page">{displayName}</span>
      </nav>

      <!-- Hero -->
      <header class="cat-hero">
        <h1 class="cat-title">{catH1}</h1>
        <p class="cat-sub">{catSub}</p>
        <div class="cat-intro">
          {introParas.map((para) => <p class="cat-intro__para">{para}</p>)}
        </div>
      </header>

      <!-- Tool count -->
      <div class="cat-meta">
        <span class="cat-count">{catTools.length} tool{catTools.length !== 1 ? 's' : ''}</span>
      </div>

      <!-- Tool grid -->
      <div class="tool-grid" role="list">
        {catTools.map((tool, i) => (
          <a
            href={`/tools/${tool.id}`}
            class="tool-card"
            role="listitem"
            aria-label={`${tool.name} — ${tool.category}`}
            style={`--stagger-delay: ${i * 40}ms`}
          >
            <div class="tool-card__inner">
              <div class="tool-card__name">{tool.name}</div>
              <p class="tool-card__desc">{tool.description}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Related categories -->
      {relatedCats.length > 0 && (
        <aside class="related-cats" aria-labelledby="related-cats-heading">
          <h2 id="related-cats-heading" class="related-cats__title">Related categories</h2>
          <div class="related-cats__row">
            {relatedCats.map((rc) => (
              <a href={`/category/${rc}`} class="related-cat-chip">
                {rc.charAt(0).toUpperCase() + rc.slice(1)}
              </a>
            ))}
          </div>
        </aside>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .category-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .breadcrumb__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .breadcrumb__link:hover {
    color: var(--text-primary);
  }

  .breadcrumb__sep {
    color: var(--text-subtle);
  }

  .breadcrumb__current {
    color: var(--text-primary);
  }

  /* Hero */
  .cat-hero {
    margin-bottom: var(--space-8);
    max-width: 720px;
  }

  .cat-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  .cat-sub {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: var(--space-6);
    margin-top: 0;
  }

  .cat-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cat-intro__para {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Meta */
  .cat-meta {
    margin-bottom: var(--space-4);
  }

  .cat-count {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-subtle);
  }

  /* Tool grid */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .tool-card {
    display: block;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-sharp);
    opacity: 0;
    transform: translateY(8px);
    animation: card-reveal 200ms cubic-bezier(0, 0, 0.2, 1) forwards;
    animation-delay: var(--stagger-delay, 0ms);
  }

  @keyframes card-reveal {
    to { opacity: 1; transform: translateY(0); }
  }

  .tool-card:hover {
    border-color: var(--text-muted);
  }

  .tool-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .tool-card__inner {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .tool-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .tool-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Related categories */
  .related-cats {
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-8);
  }

  .related-cats__title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }

  .related-cats__row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .related-cat-chip {
    height: 32px;
    padding: 0 var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition:
      border-color var(--duration-instant) var(--ease-sharp),
      color var(--duration-instant) var(--ease-sharp);
  }

  .related-cat-chip:hover {
    border-color: var(--text-muted);
    color: var(--text-primary);
  }

  .related-cat-chip:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
