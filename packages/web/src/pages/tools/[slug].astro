---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolRunner from '../../components/ToolRunner.svelte';
import ShareToolButton from '../../components/ShareToolButton.svelte';
import ToolCapabilityBanner from '../../components/ToolCapabilityBanner.svelte';
import { createDefaultRegistry } from '@wyreup/core';

export async function getStaticPaths() {
  const registry = createDefaultRegistry();
  const allTools = Array.from(registry.toolsById.values());

  return allTools.map((tool) => {
    // Related tools: same category (exclude self), limit 6
    const sameCategory = allTools
      .filter((t) => t.category === tool.category && t.id !== tool.id)
      .slice(0, 6);

    // Cross-output tools: same output mime, different category, limit 3
    const crossOutput = allTools
      .filter(
        (t) =>
          t.id !== tool.id &&
          t.category !== tool.category &&
          t.output?.mime === tool.output?.mime
      )
      .slice(0, 3);

    const relatedTools = [
      ...sameCategory.map((t) => ({ id: t.id, name: t.name, category: t.category, description: t.description })),
      ...crossOutput.map((t) => ({ id: t.id, name: t.name, category: t.category, description: t.description })),
    ].slice(0, 8);

    return {
      params: { slug: tool.id },
      props: {
        serializedTool: {
          id: tool.id,
          slug: tool.slug ?? tool.id,
          name: tool.name,
          description: tool.description,
          category: tool.category,
          keywords: tool.keywords ?? [],
          input: {
            accept: tool.input.accept,
            min: tool.input.min,
            max: tool.input.max,
            sizeLimit: tool.input.sizeLimit,
          },
          output: {
            mime: tool.output.mime,
            multiple: tool.output.multiple ?? false,
          },
          defaults: tool.defaults as Record<string, unknown>,
          paramSchema: tool.paramSchema as Record<string, import('@wyreup/core').ParamFieldSchema> | undefined,
          requiresWebgpu: tool.requires?.webgpu,
          requires: tool.requires
            ? { webgpu: tool.requires.webgpu, minMemoryGB: tool.requires.minMemoryGB }
            : undefined,
          memoryEstimate: tool.memoryEstimate,
        },
        relatedTools,
      },
    };
  });
}

const { serializedTool, relatedTools } = Astro.props;
const { name, description, category, keywords } = serializedTool;

const seoTitle = `${name} — Wyreup`;
const seoDescription = description;
const ogDescription = `${description} Runs entirely in your browser — no uploads.`;

const ldJson = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  description,
  applicationCategory: 'BrowserApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: 'Wyreup' },
  keywords: keywords.join(', '),
  url: `https://wyreup.com/tools/${serializedTool.id}`,
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  ogDescription={ogDescription}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(ldJson)} />
  </Fragment>

  <section class="tool-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Wyreup</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/tools" class="breadcrumb__link">Tools</a>
        <span class="breadcrumb__sep" aria-hidden="true">/</span>
        <span class="breadcrumb__current" aria-current="page">{name}</span>
      </nav>

      <header class="tool-header">
        <div class="tool-header__meta">
          <span class="tool-category-tag">{category}</span>
          {serializedTool.requiresWebgpu === 'required' && (
            <span class="badge badge--required">WebGPU only</span>
          )}
          {serializedTool.requiresWebgpu === 'preferred' && (
            <span class="badge badge--preferred">Faster on WebGPU</span>
          )}
        </div>
        <div class="tool-title-row">
          <h1 class="tool-title">{name}</h1>
          <ShareToolButton client:load toolName={name} toolDescription={description} />
        </div>
        <p class="tool-description">{description}</p>
      </header>

      <ToolCapabilityBanner client:load requires={serializedTool.requires} toolName={name} />
      <ToolRunner client:load tool={serializedTool} />

      <!-- Deliverable 4: Related tools footer -->
      {relatedTools.length > 0 && (
        <section class="related-tools" aria-labelledby="related-heading">
          <h2 id="related-heading" class="related-title">Related tools</h2>
          <div class="related-grid">
            {relatedTools.map((rt) => (
              <a href={`/tools/${rt.id}`} class="related-card" aria-label={`${rt.name} — ${rt.category}`}>
                <div class="related-card__name">{rt.name}</div>
                <div class="related-card__cat">{rt.category}</div>
                <p class="related-card__desc">{rt.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </section>
</BaseLayout>

<!-- Deliverable 6: Record this tool visit in localStorage -->
<script is:inline define:vars={{ toolId: serializedTool.id, toolName: name }}>
  (function () {
    const KEY = 'wyreup:recent-tools';
    const MAX = 10;
    try {
      const raw = localStorage.getItem(KEY);
      const existing = raw ? JSON.parse(raw) : [];
      // Remove if already present, prepend fresh entry
      const filtered = existing.filter((r) => r.id !== toolId);
      const updated = [{ id: toolId, name: toolName, ts: Date.now() }, ...filtered].slice(0, MAX);
      localStorage.setItem(KEY, JSON.stringify(updated));
    } catch {
      // localStorage unavailable — silently ignore
    }
  })();
</script>

<style>
  .tool-page {
    padding: var(--space-8) 0 var(--space-16);
  }

  .container {
    max-width: 860px;
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
  }

  .breadcrumb__link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .breadcrumb__link:hover {
    color: var(--text-primary);
  }

  .breadcrumb__sep {
    color: var(--text-subtle);
  }

  .breadcrumb__current {
    color: var(--text-primary);
  }

  /* Tool header */
  .tool-header {
    margin-bottom: var(--space-8);
  }

  .tool-header__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }

  .tool-category-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    padding: 1px 6px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .badge--required {
    background: var(--accent-dim);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .badge--preferred {
    background: var(--bg-raised);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .tool-title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }

  .tool-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 0;
  }

  .tool-description {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 600px;
  }

  /* Related tools footer (Deliverable 4) */
  .related-tools {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border-subtle);
  }

  .related-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-4);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-3);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) var(--ease-sharp);
  }

  .related-card:hover {
    border-color: var(--text-muted);
  }

  .related-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .related-card__name {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.25;
  }

  .related-card__cat {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .related-card__desc {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
