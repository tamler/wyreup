---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolSettings from '../components/ToolSettings.svelte';
import StorageSettings from '../components/StorageSettings.svelte';
import { createDefaultRegistry } from '@wyreup/core';

const registry = createDefaultRegistry();

// Build the list of heavy tools, grouping those that share an installGroup.
// Tools in the same installGroup share one download (e.g. all ffmpeg tools share ffmpeg.wasm).
// We present the group as a single entry rather than listing every individual tool.

type HeavyEntry =
  | {
      type: 'tool';
      id: string;
      name: string;
      description: string;
      installSize: number;
      slug: string;
    }
  | {
      type: 'group';
      id: string;
      name: string;
      description: string;
      installSize: number;
      toolIds: string[];
    };

const seenGroups = new Set<string>();
const heavyTools: HeavyEntry[] = [];

// Human-readable labels for each installGroup
const GROUP_LABELS: Record<string, { name: string; description: (toolIds: string[], totalMb: number) => string }> = {
  ffmpeg: {
    name: 'Audio/Video tools (ffmpeg)',
    description: (toolIds, _mb) =>
      `${toolIds.length} audio and video conversion tools powered by ffmpeg.wasm. Downloads ~30 MB on first use.`,
  },
  'image-ai': {
    name: 'Image AI tools',
    description: (toolIds, totalMb) =>
      `${toolIds.length} AI-powered image tools (background removal, upscaling, OCR Pro, image similarity). Downloads ~${totalMb} MB on first use — runs entirely on your device.`,
  },
  'nlp-standard': {
    name: 'NLP tools (sentiment, NER, summarize, embeddings)',
    description: (toolIds, totalMb) =>
      `${toolIds.length} natural language processing tools. Downloads ~${totalMb} MB on first use — runs entirely on your device.`,
  },
  'nlp-translate': {
    name: 'Text translation (M2M100)',
    description: (_toolIds, totalMb) =>
      `Translation model (${totalMb} MB). Only needed as a fallback — Chrome 131+ and Firefox use their built-in translator automatically.`,
  },
  speech: {
    name: 'Speech tools (Whisper, future TTS)',
    description: (toolIds, totalMb) =>
      `${toolIds.length} speech tool${toolIds.length === 1 ? '' : 's'} (Whisper-tiny for transcription). Downloads ~${totalMb} MB on first use — runs entirely on your device.`,
  },
  'vision-llm': {
    name: 'Vision tools (image captioning)',
    description: (toolIds, totalMb) =>
      `${toolIds.length} image-to-text tool${toolIds.length === 1 ? '' : 's'} (caption / describe / extract). Downloads ~${totalMb} MB on first use — runs entirely on your device.`,
  },
};

for (const t of registry.toolsById.values()) {
  if (t.installSize === undefined) continue;

  const group = (t as { installGroup?: string }).installGroup;
  if (group) {
    if (seenGroups.has(group)) continue;
    seenGroups.add(group);
    // Collect all tool IDs in this group
    const groupTools = Array.from(registry.toolsById.values())
      .filter((g) => (g as { installGroup?: string }).installGroup === group);
    const groupToolIds = groupTools.map((g) => g.id);
    // Sum installSize across all tools in the group
    const totalBytes = groupTools.reduce((sum, g) => sum + (g.installSize ?? 0), 0);
    const totalMb = Math.round(totalBytes / 1_000_000);
    const label = GROUP_LABELS[group];
    heavyTools.push({
      type: 'group',
      id: group,
      name: label ? label.name : group,
      description: label
        ? label.description(groupToolIds, totalMb)
        : `Tool group: ${group}. Downloads ~${totalMb} MB on first use.`,
      installSize: totalBytes,
      toolIds: groupToolIds,
    });
  } else {
    heavyTools.push({
      type: 'tool',
      id: t.id,
      name: t.name,
      description: t.description,
      installSize: t.installSize,
      slug: t.slug,
    });
  }
}
---

<BaseLayout
  title="Wyreup — Tool settings"
  description="Control which tools are cached for offline use."
>
  <div class="container settings-page">
    <h1 class="settings-title">Settings</h1>
    <StorageSettings client:load />
    <ToolSettings client:load heavyTools={heavyTools} />
  </div>
</BaseLayout>

<style>
  .settings-page {
    padding-block: var(--space-12);
    max-width: 720px;
  }

  .settings-title {
    font-family: var(--font-sans);
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-12);
  }
</style>
