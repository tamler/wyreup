---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Wyreup — File received"
  description="Processing your shared file."
>
  <div id="share-receive-root" class="container share-receive">
    <p class="share-receive__loading">Reading shared file...</p>
  </div>
</BaseLayout>

<script>
  // Read file(s) from Cache API (stashed by the service worker's share target handler)
  async function loadSharedFiles() {
    const root = document.getElementById('share-receive-root');
    if (!root) return;

    try {
      const cache = await caches.open('wyreup-share-intake');
      const metaResponse = await cache.match('/wyreup-share-meta');
      if (!metaResponse) {
        root.innerHTML = '<p class="share-receive__msg">No shared file found. <a href="/tools">Browse tools</a>.</p>';
        return;
      }

      const meta = await metaResponse.json() as { count: number; title: string | null; text: string | null; url: string | null };
      const files: File[] = [];

      for (let i = 0; i < meta.count; i++) {
        const fileResponse = await cache.match(`/wyreup-share-file-${i}`);
        if (!fileResponse) continue;
        const blob = await fileResponse.blob();
        const name = fileResponse.headers.get('X-File-Name') ?? `shared-file-${i}`;
        const type = fileResponse.headers.get('Content-Type') ?? blob.type;
        files.push(new File([blob], name, { type }));
      }

      // Clear the intake cache so we don't re-process on refresh
      await cache.delete('/wyreup-share-meta');
      for (let i = 0; i < meta.count; i++) {
        await cache.delete(`/wyreup-share-file-${i}`);
      }

      if (files.length === 0) {
        root.innerHTML = '<p class="share-receive__msg">No file data in share. <a href="/tools">Browse tools</a>.</p>';
        return;
      }

      // Trigger path (G3 from docs/triggers-security.md): give the
      // trigger system a chance to claim the shared file before we
      // navigate. If a trigger rule matches, TriggerRuntime opens the
      // preview sheet on this page and calls preventDefault; we then
      // skip the navigation so the user stays on the sheet.
      const file = files[0];
      const dt = new DataTransfer();
      dt.items.add(file);
      const matchEvent = new CustomEvent('wyreup:filedrop', {
        detail: { files: dt.files },
        cancelable: true,
      });
      document.dispatchEvent(matchEvent);
      if (matchEvent.defaultPrevented) {
        // A trigger rule claimed it. The preview sheet is on screen.
        // Replace the "Reading shared file..." copy with a quiet stub.
        root.innerHTML = '<p class="share-receive__msg">Matched a trigger rule — see the preview above.</p>';
        return;
      }

      // No trigger rule matched. Continue the original share-target
      // flow: stash the file in sessionStorage and navigate to '/' so
      // HeroDrop can route it to a tool.
      const MAX_SHARE_BYTES = 10 * 1024 * 1024;
      if (file.size > MAX_SHARE_BYTES) {
        root.innerHTML = '<p class="share-receive__msg">Shared file exceeds 10 MB. Open Wyreup directly and upload from <a href="/tools">/tools</a>.</p>';
        return;
      }

      const buf = await file.arrayBuffer();
      const payload = {
        name: file.name,
        type: file.type,
        data: Array.from(new Uint8Array(buf)),
      };
      try {
        sessionStorage.setItem('wyreup:shared-file', JSON.stringify(payload));
      } catch (err) {
        console.error('Could not stash shared file in sessionStorage:', err);
        root.innerHTML = '<p class="share-receive__msg">Browser storage is unavailable. <a href="/tools">Browse tools</a> and upload directly.</p>';
        return;
      }

      // Clean up any stale bridge keys from older builds.
      sessionStorage.removeItem('wyreup:share-file-name');
      sessionStorage.removeItem('wyreup:share-file-type');

      // Full-page navigate to home — HeroDrop reads the payload on mount.
      window.location.href = '/';
    } catch (err) {
      console.error('share-receive error:', err);
      const root2 = document.getElementById('share-receive-root');
      if (root2) {
        root2.innerHTML = '<p class="share-receive__msg">Could not read shared file. <a href="/tools">Browse tools</a>.</p>';
      }
    }
  }

  loadSharedFiles();
</script>

<style>
  .share-receive {
    padding-block: 4rem;
    min-height: 40vh;
    display: flex;
    align-items: center;
  }

  .share-receive__loading,
  .share-receive__msg {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--text-muted);
  }

  .share-receive__msg a {
    color: var(--accent-text);
    text-decoration: none;
  }

  .share-receive__msg a:hover {
    text-decoration: underline;
  }
</style>
