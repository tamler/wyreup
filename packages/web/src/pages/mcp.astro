---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="MCP server — Wyreup for agents"
  description="An MCP server that exposes 53 Wyreup tools to Claude, Claude Code, and any MCP-compatible client. Files never leave your machine."
>
  <div class="dist-page">
    <div class="container">

      <!-- Hero -->
      <section class="dist-hero" aria-labelledby="mcp-heading">
        <h1 id="mcp-heading" class="dist-hero__title">Wyreup for agents.</h1>
        <p class="dist-hero__sub">
          An MCP server that exposes 53 tools to Claude, Claude Code, and any MCP-compatible client.
        </p>
      </section>

      <div class="section-rule" aria-hidden="true">
        <span class="section-rule__line"></span>
        <span class="section-rule__pad"></span>
      </div>

      <!-- What is MCP -->
      <section class="dist-section" aria-labelledby="what-mcp-heading">
        <h2 id="what-mcp-heading" class="dist-section__title">What is MCP</h2>
        <p class="dist-section__body">
          MCP is an open protocol that lets AI assistants call external tools.
          Wyreup's MCP server wraps all 53 Wyreup tools so your agent can compress images, redact PDFs,
          or blur faces on your machine — without your files ever leaving it.
          Learn more at <a href="https://modelcontextprotocol.io" target="_blank" rel="noopener noreferrer" class="inline-link">modelcontextprotocol.io</a>.
        </p>
      </section>

      <div class="section-rule" aria-hidden="true">
        <span class="section-rule__line"></span>
        <span class="section-rule__pad"></span>
      </div>

      <!-- Install -->
      <section class="dist-section" aria-labelledby="install-heading">
        <h2 id="install-heading" class="dist-section__title">Install in Claude Code / Claude Desktop</h2>
        <p class="dist-section__body">
          Add the following to your MCP config. The server runs via npx — no global install required.
        </p>

        <div class="code-block">
          <div class="code-block__label">MCP server config</div>
          <pre class="code-block__pre"><code>{`{
  "mcpServers": {
    "wyreup": {
      "command": "npx",
      "args": ["-y", "@wyreup/mcp"]
    }
  }
}`}</code></pre>
        </div>

        <ul class="config-locations">
          <li class="config-loc">
            <span class="config-loc__client">Claude Desktop (macOS)</span>
            <span class="config-loc__rule" aria-hidden="true"></span>
            <span class="config-loc__pad" aria-hidden="true"></span>
            <code class="config-loc__path">~/Library/Application Support/Claude/claude_desktop_config.json</code>
          </li>
          <li class="config-loc">
            <span class="config-loc__client">Claude Desktop (Windows)</span>
            <span class="config-loc__rule" aria-hidden="true"></span>
            <span class="config-loc__pad" aria-hidden="true"></span>
            <code class="config-loc__path">%APPDATA%\Claude\claude_desktop_config.json</code>
          </li>
          <li class="config-loc">
            <span class="config-loc__client">Claude Code (project)</span>
            <span class="config-loc__rule" aria-hidden="true"></span>
            <span class="config-loc__pad" aria-hidden="true"></span>
            <code class="config-loc__path">.mcp.json</code>
            <span class="config-loc__note">in your project root</span>
          </li>
        </ul>
      </section>

      <div class="section-rule" aria-hidden="true">
        <span class="section-rule__line"></span>
        <span class="section-rule__pad"></span>
      </div>

      <!-- How agents invoke tools -->
      <section class="dist-section" aria-labelledby="invoke-heading">
        <h2 id="invoke-heading" class="dist-section__title">How agents invoke Wyreup tools</h2>
        <p class="dist-section__body">
          Each Wyreup tool is a named MCP tool. Pass <code class="inline-code">input_paths</code>,
          <code class="inline-code">output_path</code> (or <code class="inline-code">output_dir</code> for multi-output tools),
          and <code class="inline-code">params</code> for tool-specific options.
        </p>
        <div class="code-block">
          <div class="code-block__label">Example MCP tool call</div>
          <pre class="code-block__pre"><code>tool: "compress"
arguments:
  input_paths: ["/Users/alice/photo.jpg"]
  output_path: "/Users/alice/photo-compressed.jpg"
  params:
    quality: 80</code></pre>
        </div>
      </section>

      <div class="section-rule" aria-hidden="true">
        <span class="section-rule__line"></span>
        <span class="section-rule__pad"></span>
      </div>

      <!-- Pair with skill callout -->
      <section class="dist-callout" aria-labelledby="skill-callout-heading">
        <div class="callout-inner">
          <h2 id="skill-callout-heading" class="callout__title">Pair with the Wyreup skill</h2>
          <p class="callout__body">
            The MCP server gives your agent the tools. The skill teaches Claude when and how to use them — recognizing file tasks, choosing the right tool, and handling results correctly.
          </p>
          <a href="/skill" class="callout__link">Install the skill &rarr;</a>
        </div>
      </section>

      <div class="section-rule" aria-hidden="true">
        <span class="section-rule__line"></span>
        <span class="section-rule__pad"></span>
      </div>

      <!-- Related -->
      <nav class="dist-related" aria-label="Related pages">
        <span class="dist-related__label">Also</span>
        <a href="/tools" class="dist-related__link">Tools</a>
        <span class="dist-related__sep" aria-hidden="true">/</span>
        <a href="/cli" class="dist-related__link">CLI</a>
        <span class="dist-related__sep" aria-hidden="true">/</span>
        <a href="/skill" class="dist-related__link">Agent skill</a>
      </nav>

    </div>
  </div>
</BaseLayout>

<style>
  .dist-page {
    padding: var(--space-12) 0 var(--space-16);
  }

  .container {
    max-width: 800px;
  }

  /* ── Hero ── */
  .dist-hero {
    margin-bottom: var(--space-12);
  }

  .dist-hero__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .dist-hero__sub {
    font-size: var(--text-md);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 560px;
    font-family: var(--font-sans);
  }

  /* ── Section divider ── */
  .section-rule {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-10) 0;
  }

  .section-rule__line {
    display: block;
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .section-rule__pad {
    display: block;
    width: 3px;
    height: 3px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Sections ── */
  .dist-section__title {
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .dist-section__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 640px;
    margin-bottom: var(--space-6);
    font-family: var(--font-sans);
  }

  /* ── Code blocks ── */
  .code-block {
    margin-bottom: var(--space-4);
  }

  .code-block__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-2);
  }

  .code-block__pre {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
  }

  .code-block__pre code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    line-height: 1.6;
  }

  .inline-code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    background: var(--bg-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 1px 4px;
  }

  /* ── Config locations ── */
  .config-locations {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .config-loc {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    row-gap: var(--space-1);
  }

  .config-loc__client {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .config-loc__rule {
    display: block;
    flex: 1;
    min-width: 16px;
    height: 1px;
    background: var(--border-subtle);
  }

  .config-loc__pad {
    display: block;
    width: 5px;
    height: 5px;
    background: var(--border);
    flex-shrink: 0;
  }

  .config-loc__path {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-primary);
    white-space: nowrap;
  }

  .config-loc__note {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--text-subtle);
  }

  /* ── Callout ── */
  .dist-callout {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1px;
  }

  .callout-inner {
    background: var(--accent-dim);
    border: 1px solid var(--border-subtle);
    border-radius: calc(var(--radius-md) - 1px);
    padding: var(--space-6);
  }

  .callout__title {
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
    font-family: var(--font-sans);
  }

  .callout__body {
    font-size: var(--text-base);
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
  }

  .callout__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .callout__link:hover {
    color: var(--accent-hover);
  }

  /* ── Related ── */
  .dist-related {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-10);
  }

  .dist-related__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .dist-related__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .dist-related__link:hover {
    color: var(--text-primary);
  }

  .dist-related__sep {
    color: var(--text-subtle);
    font-size: var(--text-xs);
  }

  /* ── Inline link ── */
  .inline-link {
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--duration-instant) var(--ease-sharp);
  }

  .inline-link:hover {
    color: var(--text-primary);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .config-loc__rule,
    .config-loc__pad {
      display: none;
    }

    .config-loc {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
