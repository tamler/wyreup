{
  "name": "@wyreup/cli",
  "version": "0.2.0",
  "description": "Wyreup CLI — run privacy-first file tools from the shell. Same engine as wyreup.com, scriptable and offline.",
  "keywords": [
    "wyreup",
    "cli",
    "privacy",
    "image",
    "pdf",
    "compress",
    "convert",
    "offline",
    "local",
    "shell"
  ],
  "license": "MIT",
  "homepage": "https://wyreup.com/cli",
  "bugs": {
    "url": "https://github.com/tamler/wyreup/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamler/wyreup.git",
    "directory": "packages/cli"
  },
  "author": "Wyreup Contributors",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "wyreup": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@wyreup/core": "workspace:*",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
