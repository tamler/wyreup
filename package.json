{
  "name": "wyreup-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Wyreup — free, privacy-first tool library",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.0.6",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev --parallel",
    "dev:pages": "pnpm --filter @wyreup/web build && wrangler pages dev packages/web/dist",
    "db:apply:local": "wrangler d1 migrations apply wyreup-prod --local",
    "db:apply:remote": "wrangler d1 migrations apply wyreup-prod --remote",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:root": "eslint .",
    "test:root": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.60.0",
    "prettier": "^3.3.0",
    "turbo": "^2.9.14",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.84.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "^3.1.2",
      "protobufjs": "^7.5.6",
      "serialize-javascript": "^7.0.3",
      "devalue": "^5.8.1",
      "tmp": "^0.2.6"
    }
  }
}
